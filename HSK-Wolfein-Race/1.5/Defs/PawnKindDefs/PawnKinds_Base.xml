<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <PawnKindDef Name="Wolfein_PawnBase" Abstract="True">
        <race>Wolfein_Race</race>
		<fixedGender>Female</fixedGender>
        <defaultFactionType>Wolfein_PlayerFaction</defaultFactionType>
        <backstoryCryptosleepCommonality>0</backstoryCryptosleepCommonality>
        <invNutrition>0</invNutrition>
        <gearHealthRange>0.8~1.0</gearHealthRange>
        <apparelIgnoreSeasons>true</apparelIgnoreSeasons>
        <initialWillRange>3~5</initialWillRange>
        <initialResistanceRange>12~20</initialResistanceRange>
        <maxGenerationAge>50</maxGenerationAge>
        <minGenerationAge>18</minGenerationAge>
        <styleItemTags>
            <li>
                <tag>Wolfein</tag>
                <baseWeight>1</baseWeight>
                <weightFactor>1</weightFactor>
            </li>
        </styleItemTags>
        <xenotypeSet>
            <xenotypeChances>
                <Baseliner MayRequire="Ludeon.RimWorld.Biotech">1</Baseliner>
                <Dirtmole MayRequire="Ludeon.RimWorld.Biotech">0</Dirtmole>
                <Genie MayRequire="Ludeon.RimWorld.Biotech">0</Genie>
                <Hussar MayRequire="Ludeon.RimWorld.Biotech">0</Hussar>
                <Sanguophage MayRequire="Ludeon.RimWorld.Biotech">0</Sanguophage>
                <Neanderthal MayRequire="Ludeon.RimWorld.Biotech">0</Neanderthal>
                <Pigskin MayRequire="Ludeon.RimWorld.Biotech">0</Pigskin>
                <Impid MayRequire="Ludeon.RimWorld.Biotech">0</Impid>
                <Waster MayRequire="Ludeon.RimWorld.Biotech">0</Waster>
                <Yttakin MayRequire="Ludeon.RimWorld.Biotech">0</Yttakin>
                <Highmate MayRequire="Ludeon.RimWorld.Biotech">0</Highmate>
            </xenotypeChances>
        </xenotypeSet>
        <useFactionXenotypes>false</useFactionXenotypes>
    </PawnKindDef>

    <PawnKindDef Name="Wolfein_PawnBase_MegaCorp" ParentName="Wolfein_PawnBase" Abstract="True">
        <defaultFactionType>Wolfein_Faction_MegaCorp</defaultFactionType>
        <invNutrition>0</invNutrition>
        <gearHealthRange>0.9~1.0</gearHealthRange>
        <maxGenerationAge>38</maxGenerationAge>
        <minGenerationAge>21</minGenerationAge>
        <initialWillRange>8~10</initialWillRange>
        <initialResistanceRange>8~10</initialResistanceRange>
        <biocodeWeaponChance>0.6</biocodeWeaponChance>
        <inventoryOptions>
            <subOptionsTakeAll>
                <li>
                    <thingDef>Wolfein_PackingStaffMeals</thingDef>
                    <countRange>
                        <min>0</min>
                        <max>3</max>
                    </countRange>
                </li>
                <li>
                    <skipChance>0.65</skipChance>
                    <thingDef>Wolfein_EclipseTrigger</thingDef>
                </li>
                <li>
                    <skipChance>0.85</skipChance>
                    <thingDef>Silver</thingDef>
                    <countRange>
                        <min>25</min>
                        <max>80</max>
                    </countRange>
                </li>
            </subOptionsTakeAll>
        </inventoryOptions>
    </PawnKindDef>

    <!-- 抵抗军 -->
    <PawnKindDef Name="Wolfein_PawnBase_Rebel" ParentName="Wolfein_PawnBase" Abstract="True">
        <defaultFactionType>Wolfein_Faction_Rebel</defaultFactionType>
        <biocodeWeaponChance>0.2</biocodeWeaponChance>
        <inventoryOptions>
            <subOptionsTakeAll>
                <li>
                    <thingDef>Wolfein_ResistanceArmyRations</thingDef>
                    <countRange>
                        <min>0</min>
                        <max>3</max>
                    </countRange>
                </li>
                <li>
                    <skipChance>0.85</skipChance>
                    <thingDef>Wolfein_EclipseTrigger</thingDef>
                </li>
                <li>
                    <skipChance>0.85</skipChance>
                    <thingDef>Silver</thingDef>
                    <countRange>
                        <min>10</min>
                        <max>40</max>
                    </countRange>
                </li>
            </subOptionsTakeAll>
        </inventoryOptions>
    </PawnKindDef>


</Defs>