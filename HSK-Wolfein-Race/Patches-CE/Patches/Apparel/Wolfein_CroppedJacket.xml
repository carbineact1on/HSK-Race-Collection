<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 短款夹克（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_CroppedJacket"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>300</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>1</Mass>
            <EquipDelay>1.5</EquipDelay>
            <WorkToMake>15000</WorkToMake>
            <Insulation_Cold>6</Insulation_Cold>
            <Insulation_Heat>8</Insulation_Heat>
            <ArmorRating_Sharp>0.3</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.5</ArmorRating_Blunt>
            <ArmorRating_Heat>0.1</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>1</Bulk>
            <WornBulk>1.3</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_CroppedJacket"]/equippedStatOffsets</xpath>
		<value>
      <CarryBulk>5</CarryBulk>
      <CarryWeight>3</CarryWeight>
		</value>
	</Operation>

</Patch>
