<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 流浪者拼接大衣（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_WastelandSplicingcoat"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>2</Mass>
            <EquipDelay>3</EquipDelay>
            <WorkToMake>15000</WorkToMake>
            <StuffEffectMultiplierArmor>1</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>1</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>1</StuffEffectMultiplierInsulation_Heat>
            <ArmorRating_Sharp>2.1</ArmorRating_Sharp>
            <ArmorRating_Blunt>2.3</ArmorRating_Blunt>
            <ArmorRating_Heat>0</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>1</Bulk>
            <WornBulk>1.8</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_WastelandSplicingcoat"]/equippedStatOffsets</xpath>
		<value>
      <CarryBulk>12</CarryBulk>
      <CarryWeight>11</CarryWeight>
		</value>
	</Operation>
</Patch>
