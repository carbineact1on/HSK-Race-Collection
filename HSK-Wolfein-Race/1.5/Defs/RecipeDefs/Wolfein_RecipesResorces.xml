        <effectWorking>Tailor</effectWorking>
        <recipeUsers>
            <li>ElectricSmithy</li>
        </recipeUsers>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Silver</li>
                    </thingDefs>
                </filter>
                <count>6</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>40</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Plasteel</li>
                    </thingDefs>
                </filter>
                <count>40</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Silver</li>
                <li>Plasteel</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Wolfein_AlloyMaterials>75</Wolfein_AlloyMaterials>
        </products>
        <skillRequirements>
            <Crafting>6</Crafting>
        </skillRequirements>
        <workSkill>Crafting</workSkill>
        <researchPrerequisite>Wolfein_Industrial_production</researchPrerequisite>
    </RecipeDef>

    <!-- 沃芬包装员工餐 -->
    <RecipeDef ParentName="CookMealBase">
        <defName>Cook_Wolfein_PackingStaffMeals</defName>
        <label>cook Wolfein Packing Staff Meals</label>
        <description>Preparing packaged staff meals for the Wolfein.</description>
        <jobString>cook Wolfein Packing Staff Meals.</jobString>
        <workSpeedStat>CookSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_CookMeal</soundWorking>
        <allowMixingIngredients>true</allowMixingIngredients>
        <ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>
        <ingredients>
            <li>
                <filter>
                    <customSummary>protein</customSummary>
                    <categories>
                        <li>MeatRaw</li>
                        <li>AnimalProductRaw</li>
                    </categories>
                </filter>
                <count>0.30</count>
            </li>
            <li>
                <filter>
                    <categories>
                        <li>PlantFoodRaw</li>
                    </categories>
                </filter>
                <count>0.25</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>PsychoidLeaves</li>
                    </thingDefs>
                </filter>
                <count>0.1</count>
            </li>
        </ingredients>
        <products>
            <Wolfein_PackingStaffMeals>1</Wolfein_PackingStaffMeals>
        </products>
        <recipeUsers>
            <li>FueledStove</li>
            <li>ElectricStove</li>
        </recipeUsers>
        <skillRequirements>
            <Cooking>5</Cooking>
        </skillRequirements>
        <researchPrerequisite>Wolfein_PackagedFood</researchPrerequisite>
    </RecipeDef>
