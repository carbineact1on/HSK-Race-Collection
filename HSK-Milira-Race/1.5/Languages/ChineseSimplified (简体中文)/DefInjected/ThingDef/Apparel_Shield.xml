<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN: Milian feather shield -->
  <Milian_FeatherShapeShield.label>米莉安羽形盾</Milian_FeatherShapeShield.label>
  <!-- EN: A medium-sized shield commonly used by Milians, shaped like a feather. Cannot shoot while holding it. -->
  <Milian_FeatherShapeShield.description>米莉安常用的羽毛形状的中型盾牌。持有时无法射击。</Milian_FeatherShapeShield.description>
  <!-- EN: rise up shield. -->
  <Milian_FeatherShapeShield.comps.CompPhysicalShield.gizmoDesc>举起盾牌以防御来自正面的攻击。</Milian_FeatherShapeShield.comps.CompPhysicalShield.gizmoDesc>
  <!-- EN: rise shield -->
  <Milian_FeatherShapeShield.comps.CompPhysicalShield.gizmoLabel>持盾防御</Milian_FeatherShapeShield.comps.CompPhysicalShield.gizmoLabel>
  
  <!-- EN: Milian knight shield -->
  <Milian_KnightShield.label>米莉安骑士盾</Milian_KnightShield.label>
  <!-- EN: A lightweight knight shield commonly used by Milian. -->
  <Milian_KnightShield.description>米莉安常用的轻型骑士盾牌。</Milian_KnightShield.description>
  <!-- EN: rise up shield. -->
  <Milian_KnightShield.comps.CompPhysicalShield.gizmoDesc>举起盾牌以防御来自正面的攻击。</Milian_KnightShield.comps.CompPhysicalShield.gizmoDesc>
  <!-- EN: rise shield -->
  <Milian_KnightShield.comps.CompPhysicalShield.gizmoLabel>持盾防御</Milian_KnightShield.comps.CompPhysicalShield.gizmoLabel>
  
  <!-- EN: Milian cyclops gate shield -->
  <Milian_RookShield.label>米莉安独眼城门盾</Milian_RookShield.label>
  <!-- EN: A heavy shield commonly used by Milians, as thick and imposing as a massive city wall. The holder cannot shoot while holding it. -->
  <Milian_RookShield.description>米莉安常用的重型盾牌，犹如一面巨大的城墙一般厚重。持有时无法射击。</Milian_RookShield.description>
  <!-- EN: rise up shield. -->
  <Milian_RookShield.comps.CompPhysicalShield.gizmoDesc>举起盾牌以防御来自正面的攻击。</Milian_RookShield.comps.CompPhysicalShield.gizmoDesc>
  <!-- EN: rise shield -->
  <Milian_RookShield.comps.CompPhysicalShield.gizmoLabel>持盾防御</Milian_RookShield.comps.CompPhysicalShield.gizmoLabel>
  
</LanguageData>