    <!-- 炮塔 -->
    <ThingDef ParentName="BaseWeaponTurret">
        <defName>Wolfein_GiantTurret</defName>
        <label>Extra Heavy Multi-Legged Firepower Platform Main Cannon.</label>
        <description>The main offensive system of the Extra Heavy Multi-Legged Firepower Platform; it can be said that the platform was designed primarily to deliver this heavy cannon to the frontline where it is needed most..</description>
        <tradeability>None</tradeability>
        <destroyOnDrop>true</destroyOnDrop>
        <graphicData>
            <texPath>Wolfein/Mech/MegaCorpGiant/MegaCorpGiantTop</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <Mass>2.6</Mass>
            <AccuracyTouch>0.60</AccuracyTouch>
            <AccuracyShort>0.80</AccuracyShort>
            <AccuracyMedium>0.90</AccuracyMedium>
            <AccuracyLong>0.85</AccuracyLong>
        </statBases>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <defaultProjectile>W_Bullet_Missile</defaultProjectile>
                <range>44.9</range>
                <minRange>3.9</minRange>
                <forcedMissRadius>1.9</forcedMissRadius>
                <soundCast>Shot_IncendiaryLauncher</soundCast>
                <soundCastTail>GunTail_Heavy</soundCastTail>
                <muzzleFlashScale>9</muzzleFlashScale>
                <defaultCooldownTime>10</defaultCooldownTime>
                <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
                <ticksBetweenBurstShots>150</ticksBetweenBurstShots>
                <ai_AvoidFriendlyFireRadius>6</ai_AvoidFriendlyFireRadius>
                <ai_RangedAlawaysShootGroundBelowTarget>true</ai_RangedAlawaysShootGroundBelowTarget>
                <ai_ProjectileLaunchingIgnoresMeleeThreats>true</ai_ProjectileLaunchingIgnoresMeleeThreats>
                <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
                <!-- <requireLineOfSight>false</requireLineOfSight> -->
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
            </li>
        </verbs>
    </ThingDef>
    <!-- 炮塔 -->
    <ThingDef ParentName="BaseWeaponTurret">
        <defName>Wolfein_GiantTurret_MechineGun</defName>
        <label>Extra Heavy Multi-Legged Firepower Platform Machine Gun.</label>
        <description>A rapid-fire machine gun mounted on the turret, capable of clearing out units attempting to enter the main cannon’s blind spots..</description>
        <tradeability>None</tradeability>
        <destroyOnDrop>true</destroyOnDrop>
        <graphicData>
            <texPath>Wolfein/Mech/MegaCorpGiant/MegaCorpGiantTop</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <Mass>2.6</Mass>
            <AccuracyTouch>0.85</AccuracyTouch>
            <AccuracyShort>0.55</AccuracyShort>
            <AccuracyMedium>0.42</AccuracyMedium>
            <AccuracyLong>0.35</AccuracyLong>
        </statBases>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <defaultProjectile>W_ChargeBullet_Medium</defaultProjectile>
                <range>31.9</range>
                <soundCast>Wolfein_Shot_AR_MG</soundCast>
                <soundCastTail>GunTail_Heavy</soundCastTail>
                <muzzleFlashScale>9</muzzleFlashScale>
