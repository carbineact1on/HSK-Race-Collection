            <li>
                <filter>
                    <thingDefs>
                        <li>Wolfein_ElectronicComponent</li>
                    </thingDefs>
                </filter>
                <count>2</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Wolfein_MechanicalComponent</li>
                    </thingDefs>
                </filter>
                <count>2</count>
