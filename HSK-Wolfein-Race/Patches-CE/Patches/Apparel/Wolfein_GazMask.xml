<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 防毒面罩（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_GazMask"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <Flammability>0.4</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>1.5</Mass>
            <EquipDelay>1</EquipDelay>
            <WorkToMake>8000</WorkToMake>
            <Insulation_Cold>6</Insulation_Cold>
            <Insulation_Heat>8</Insulation_Heat>
            <ArmorRating_Sharp>0.4</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.5</ArmorRating_Blunt>
            <ArmorRating_Heat>0.1</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>1</Bulk>
            <WornBulk>1.8</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_GazMask"]/equippedStatOffsets</xpath>
		<value>
      <SmokeSensitivity>-1</SmokeSensitivity>
		</value>
	</Operation>

</Patch>
