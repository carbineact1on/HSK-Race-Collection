<?xml version="1.0" encoding="utf-8" ?>
<!--
    HSK + Combat Extended patches for VRE Sanguophage.

    HSK MATERIAL CONVERSION
    =======================
    Each Sanguophage building's costList is rewritten to match the equivalent
    vanilla-Biotech building's HSK pattern from
    Core_SK/Biotech/Patches/ThingDefs_Buildings/Buildings_Deathrest.xml:

      vanilla DeathrestCasket       (HSK: stuff 80, CompInd 3, ElecComp 1, Mech 1, Electronics 1)
      vanilla Hemopump              (HSK: stuff 80, CompInd 2, ElecComp 1, Mech 2, Rubber 8, Plastic 8, HemogenPack 5)
      vanilla HemogenAmplifier      (HSK: stuff 160, CompInd 4, ElecComp 2, Electronics 2, Rubber 6, Plastic 10, HemogenPack 5)
      vanilla DeathrestAccelerator  (HSK: stuff 200, CompInd 6, ElecComp 2, Microchips 2, Plastic 10, HemogenPack 5)
      vanilla PsychofluidPump       (HSK: stuff 50, CompInd 6, ElecComp 2, Mech 2, Electronics 1, Rubber 12, CarbonAlloy 10, HemogenPack 5)

    Mapping:
      VRE_SmallHemopump            → small-tier Hemopump        (1x1, downscaled)
      VRE_SmallHemogenAmplifier    → small-tier HemogenAmplifier (1x1, downscaled)
      VRE_HemogenSolidifier        → full HemogenAmplifier-tier (1x2, mid-tier processor)
      VRE_HemodynamicAccelerator   → DeathrestAccelerator-tier  (2x2, large)
      VRE_InvocationMatrix         → custom ritual (Gold kept for ritual flavor + components)
      VRE_PsychofluidWell (Royalty)→ PsychofluidPump-tier       (Plasteel kept for advanced housing)

    All buildings switch from fixed Steel to stuffCategories Metallic +
    costStuffCount per HSK convention so user can build them from any metal
    (Steel, SteelBar, Plasteel, etc.) with appropriate hardness/beauty.

    HemogenPack kept as a "fuel" cost (vanilla-Biotech HSK convention for
    Sanguophage equipment).

    CE PATCH
    ========
    VRE_SharpTalons hediff — talons tool converted to CombatExtended.ToolCE
    with armorPenetrationSharp 0.65 / armorPenetrationBlunt 2.0, calibrated
    against Saurid claws (Sharp 0.5) — talons are sharper per the lore.
-->
<Patch>

    <!-- ============================================================ -->
    <!--  HSK BUILDING REBALANCE (stuff + components + minor mats)    -->
    <!-- ============================================================ -->

    <!-- VRE_SmallHemopump (1x1, small Hemopump) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_SmallHemopump"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>50</costStuffCount>
            <costList>
                <ComponentIndustrial>2</ComponentIndustrial>
                <ElectronicComponents>1</ElectronicComponents>
                <Mechanism>1</Mechanism>
                <Rubber>4</Rubber>
                <Plastic>4</Plastic>
                <HemogenPack>5</HemogenPack>
            </costList>
        </value>
    </Operation>

    <!-- VRE_SmallHemogenAmplifier (1x1, small HemogenAmplifier) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_SmallHemogenAmplifier"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>100</costStuffCount>
            <costList>
                <ComponentIndustrial>3</ComponentIndustrial>
                <ElectronicComponents>1</ElectronicComponents>
                <Electronics>1</Electronics>
                <Rubber>3</Rubber>
                <Plastic>5</Plastic>
                <HemogenPack>5</HemogenPack>
            </costList>
        </value>
    </Operation>

    <!-- VRE_HemogenSolidifier (1x2, mid-tier hemogen processor — HemogenAmplifier full pattern) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemogenSolidifier"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>200</costStuffCount>
            <costList>
                <ComponentIndustrial>4</ComponentIndustrial>
                <ElectronicComponents>2</ElectronicComponents>
                <Mechanism>2</Mechanism>
                <Rubber>8</Rubber>
                <Plastic>8</Plastic>
                <HemogenPack>5</HemogenPack>
            </costList>
        </value>
    </Operation>

    <!-- VRE_HemodynamicAccelerator (2x2, DeathrestAccelerator-tier) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemodynamicAccelerator"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>200</costStuffCount>
            <costList>
                <ComponentIndustrial>6</ComponentIndustrial>
                <ElectronicComponents>2</ElectronicComponents>
                <Microchips>2</Microchips>
                <Plastic>10</Plastic>
                <HemogenPack>10</HemogenPack>
            </costList>
        </value>
    </Operation>

    <!-- VRE_InvocationMatrix (2x2, ritual building — keep Gold flavor) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_InvocationMatrix"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>120</costStuffCount>
            <costList>
                <GoldBar>40</GoldBar>
                <ComponentIndustrial>4</ComponentIndustrial>
                <ElectronicComponents>1</ElectronicComponents>
                <Microchips>1</Microchips>
                <HemogenPack>5</HemogenPack>
            </costList>
        </value>
    </Operation>

    <!-- VRE_PsychofluidWell (2x2, Royalty DLC, PsychofluidPump-tier) -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Royalty</li>
        </mods>
        <match Class="PatchOperationReplace">
            <xpath>Defs/ThingDef[defName="VRE_PsychofluidWell"]/costList</xpath>
            <value>
                <stuffCategories>
                    <li>Metallic</li>
                </stuffCategories>
                <costStuffCount>100</costStuffCount>
                <costList>
                    <Plasteel>100</Plasteel>
                    <ComponentIndustrial>6</ComponentIndustrial>
                    <ElectronicComponents>2</ElectronicComponents>
                    <Mechanism>2</Mechanism>
                    <Electronics>1</Electronics>
                    <Rubber>12</Rubber>
                    <CarbonAlloy>10</CarbonAlloy>
                    <HemogenPack>5</HemogenPack>
                </costList>
            </value>
        </match>
    </Operation>

    <!-- ============================================================ -->
    <!--  CE PATCH — SharpTalons hediff to ToolCE                     -->
    <!-- ============================================================ -->

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/HediffDef[defName="VRE_SharpTalons"]/comps/li[@Class="HediffCompProperties_VerbGiver"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>talons</label>
                    <capacities>
                        <li>Cut</li>
                    </capacities>
                    <power>16</power>
                    <cooldownTime>2</cooldownTime>
                    <armorPenetrationSharp>0.65</armorPenetrationSharp>
                    <armorPenetrationBlunt>2</armorPenetrationBlunt>
                </li>
            </tools>
        </value>
    </Operation>

    <!-- ============================================================ -->
    <!--  HEMOGEN NETWORK (BloodNet.xml) — was using raw Steel/Gold   -->
    <!--  which displays as raw Magnetite / Native Gold under Vile's  -->
    <!--  Materials Science. Patched to HSK Biotech pattern:          -->
    <!--  refined SteelBar/GoldBar + HSK component pipeline.          -->
    <!-- ============================================================ -->

    <!-- VRE_HemogenPipe (small pipe segment) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemogenPipe"]/costList</xpath>
        <value>
            <costList>
                <SteelBar>3</SteelBar>
                <Wire>1</Wire>
            </costList>
        </value>
    </Operation>

    <!-- VRE_UndergroundHemogenPipe (buried pipe variant) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_UndergroundHemogenPipe"]/costList</xpath>
        <value>
            <costList>
                <SteelBar>6</SteelBar>
                <Wire>2</Wire>
            </costList>
        </value>
    </Operation>

    <!-- VRE_HemogenValve (small valve) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemogenValve"]/costList</xpath>
        <value>
            <costList>
                <SteelBar>5</SteelBar>
                <Wire>1</Wire>
                <Rubber>1</Rubber>
            </costList>
        </value>
    </Operation>

    <!-- VRE_HemogenVat (large hemogen storage — HemogenAmplifier-tier) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemogenVat"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>160</costStuffCount>
            <costList>
                <ComponentIndustrial>4</ComponentIndustrial>
                <ElectronicComponents>2</ElectronicComponents>
                <Electronics>2</Electronics>
                <Rubber>6</Rubber>
                <Plastic>10</Plastic>
                <HemogenPack>5</HemogenPack>
            </costList>
        </value>
    </Operation>

    <!-- VRE_HemogenTap (network output dispenser — Hemopump small-tier) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemogenTap"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>50</costStuffCount>
            <costList>
                <ComponentIndustrial>2</ComponentIndustrial>
                <ElectronicComponents>1</ElectronicComponents>
                <Mechanism>1</Mechanism>
                <Rubber>4</Rubber>
                <Plastic>4</Plastic>
            </costList>
        </value>
    </Operation>

    <!-- VRE_HemogenDrain (network input feeder — same tier as Tap) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemogenDrain"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>45</costStuffCount>
            <costList>
                <ComponentIndustrial>2</ComponentIndustrial>
                <ElectronicComponents>1</ElectronicComponents>
                <Mechanism>1</Mechanism>
                <Rubber>4</Rubber>
                <Plastic>4</Plastic>
            </costList>
        </value>
    </Operation>

    <!-- VRE_Draincasket (large 2x2 hemogen-extracting prison — DeathrestCasket scaled up) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_Draincasket"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>180</costStuffCount>
            <costList>
                <ComponentIndustrial>4</ComponentIndustrial>
                <ElectronicComponents>2</ElectronicComponents>
                <Mechanism>2</Mechanism>
                <Electronics>1</Electronics>
                <Rubber>6</Rubber>
                <Plastic>8</Plastic>
                <HemogenPack>5</HemogenPack>
            </costList>
        </value>
    </Operation>

    <!-- Strip inherited constructEffect on stuff-converted buildings
         (madeFromStuff + constructEffect = config error) -->
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="VRE_HemogenVat"]/constructEffect</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="VRE_Draincasket"]/constructEffect</xpath>
    </Operation>

</Patch>
