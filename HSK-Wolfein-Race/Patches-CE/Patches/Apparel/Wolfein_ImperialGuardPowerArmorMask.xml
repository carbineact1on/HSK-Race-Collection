<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 前世代动力甲防护面罩（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_ImperialGuardPowerArmorMask"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>350</MaxHitPoints>
            <Flammability>0.4</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>1</Mass>
            <EquipDelay>3</EquipDelay>
            <WorkToMake>23000</WorkToMake>
            <Insulation_Cold>8</Insulation_Cold>
            <Insulation_Heat>5</Insulation_Heat>
            <ArmorRating_Sharp>15.8</ArmorRating_Sharp>
            <ArmorRating_Blunt>27.8</ArmorRating_Blunt>
            <ArmorRating_Heat>0.1</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>1</Bulk>
            <WornBulk>1.2</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_ImperialGuardPowerArmorMask"]/equippedStatOffsets</xpath>
		<value>
      <SmokeSensitivity>-1</SmokeSensitivity>
		</value>
	</Operation>

</Patch>
