<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <HediffDef>
        <defName>Wolfein_NightStrength</defName>
        <label>Night wolfein strength</label>
        <labelNoun>a period of enhancement</labelNoun>
        <description>An enhancement that occurs in wolfeins over a period of time, often at night.</description>
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.52, 0.91, 0.00)</defaultLabelColor>
        <initialSeverity>0</initialSeverity>
        <maxSeverity>1</maxSeverity>
        <everCurableByItem>false</everCurableByItem>
        <comps>
            <li Class="Wolfein.HediffCompProperties_WolfeinNightStrength">
                <intervalTicks>250</intervalTicks>
                <hediffInHourIntegers>
                    <li>
                        <hourInterval>18~19</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.2</severity>
                    </li>
                    <li>
                        <hourInterval>19~21</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.3</severity>
                    </li>
                    <li>
                        <hourInterval>21~23</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.4</severity>
                    </li>
                    <li>
                        <hourInterval>23~24</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.5</severity>
                    </li>
                    <li>
                        <hourInterval>0~2</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.5</severity>
                    </li>
                    <li>
                        <hourInterval>2~4</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.4</severity>
                    </li>
                    <li>
                        <hourInterval>4~5</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.3</severity>
                    </li>
                    <li>
                        <hourInterval>5~6</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.2</severity>
                    </li>
                    <li>
                        <hourInterval>6~18</hourInterval>
                        <hediff>Wolfein_NightStrength</hediff>
                        <severity>0.1</severity>
                    </li>
                </hediffInHourIntegers>
            </li>
        </comps>
        <stages>
            <li>
                <label>disable</label>
                <becomeVisible>false</becomeVisible>
            </li>
            <li>
                <label>initial</label>
                <minSeverity>0.2</minSeverity>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.05</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <label>minor</label>
                <minSeverity>0.3</minSeverity>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>0.1</offset>
                    </li>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.1</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <label>serious</label>
                <minSeverity>0.4</minSeverity>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>0.25</offset>
                    </li>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.2</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <label>extreme</label>
                <minSeverity>0.5</minSeverity>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>0.35</offset>
                    </li>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.3</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>Wolfein_MoonStrength</defName>
        <label>Wolfein Lunar Phase Effect</label>
        <description>The physiological state of the Wolfein species fluctuates at night in response to lunar phases. As the full moon approaches, their sensory perception, reaction speed, and aggression intensify. These effects are especially pronounced in pureblood individuals.</description>
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.52, 0.91, 0.00)</defaultLabelColor>
        <initialSeverity>0</initialSeverity>
        <maxSeverity>1</maxSeverity>
        <everCurableByItem>false</everCurableByItem>
        <comps>
            <li Class="Wolfein.HediffCompProperties_WolfeinMoonStrength">
                <intervalTicks>5000</intervalTicks>
                <moonPhaseHediff>
                    <!-- 衰弱期 -->
                    <li>
                        <moonPhase>WaningCrescent</moonPhase>
                        <severity>0.1</severity>
                        <severity_PureBlood>0.5</severity_PureBlood>
                    </li>
                    <li>
                        <moonPhase>NewMoon</moonPhase>
                        <severity>0.2</severity>
                        <severity_PureBlood>0.6</severity_PureBlood>
                    </li>
                    <li>
                        <moonPhase>WaxingCrescent</moonPhase>
                        <severity>0.1</severity>
                        <severity_PureBlood>0.5</severity_PureBlood>
                    </li>
                    <!-- 强化期 -->
                    <li>
                        <moonPhase>WaxingGibbous</moonPhase>
                        <severity>0.3</severity>
                        <severity_PureBlood>0.7</severity_PureBlood>
                    </li>
                    <li>
                        <moonPhase>FullMoon</moonPhase>
                        <severity>0.4</severity>
                        <severity_PureBlood>0.8</severity_PureBlood>
                    </li>
                    <li>
                        <moonPhase>WaningGibbous</moonPhase>
                        <severity>0.3</severity>
                        <severity_PureBlood>0.7</severity_PureBlood>
                    </li>
                </moonPhaseHediff>
            </li>
        </comps>
        <stages>
            <li>
                <label>disable</label>
                <becomeVisible>false</becomeVisible>
            </li>
            <li>
                <label>New Moon (Half)</label>
                <minSeverity>0.1</minSeverity>
                <statFactors>
                    <AimingDelayFactor>1.1</AimingDelayFactor>
                    <MeleeDamageFactor>0.9</MeleeDamageFactor>
                </statFactors>
            </li>
            <li>
                <label>New Moon (Full)</label>
                <minSeverity>0.2</minSeverity>
                <statFactors>
                    <AimingDelayFactor>1.2</AimingDelayFactor>
                    <MeleeDamageFactor>0.8</MeleeDamageFactor>
                </statFactors>
            </li>
            <li>
                <label>Full Moon (Half)</label>
                <minSeverity>0.3</minSeverity>
                <painFactor>0.9</painFactor>
                <statFactors>
                    <AimingDelayFactor>0.9</AimingDelayFactor>
                    <MeleeDamageFactor>1.1</MeleeDamageFactor>
                </statFactors>
            </li>
            <li>
                <label>Full Moon (Full)</label>
                <minSeverity>0.4</minSeverity>
                <painFactor>0.6</painFactor>
                <statFactors>
                    <AimingDelayFactor>0.8</AimingDelayFactor>
                    <MeleeDamageFactor>1.35</MeleeDamageFactor>
                </statFactors>
            </li>
            <li>
                <label>New Moon (Pureblood - Start)</label>
                <minSeverity>0.5</minSeverity>
                <statFactors>
                    <AimingDelayFactor>1.2</AimingDelayFactor>
                    <MeleeDamageFactor>0.85</MeleeDamageFactor>
                </statFactors>
            </li>
            <li>
                <label>New Moon (Pureblood - Full)</label>
                <minSeverity>0.6</minSeverity>
                <statFactors>
                    <AimingDelayFactor>1.6</AimingDelayFactor>
                    <MeleeDamageFactor>0.5</MeleeDamageFactor>
                </statFactors>
            </li>
            <li>
                <label>Full Moon (Pureblood - Start)</label>
                <minSeverity>0.7</minSeverity>
                <painFactor>0.6</painFactor>
                <statFactors>
                    <AimingDelayFactor>0.8</AimingDelayFactor>
                    <MeleeDamageFactor>1.25</MeleeDamageFactor>
                </statFactors>
            </li>
            <li>
                <label>Full Moon (Pureblood - Full)</label>
                <minSeverity>0.8</minSeverity>
                <painFactor>0.2</painFactor>
                <statFactors>
                    <AimingDelayFactor>0.6</AimingDelayFactor>
                    <MeleeDamageFactor>1.5</MeleeDamageFactor>
                </statFactors>
            </li>
        </stages>
    </HediffDef>

</Defs>