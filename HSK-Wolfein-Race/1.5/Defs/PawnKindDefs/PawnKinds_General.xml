    <PawnKindDef ParentName="Wolfein_PawnBase">
        <defName>Wolfein_Colonist</defName>
        <label>Wolfein Colonist</label>
        <combatPower>50</combatPower>
        <itemQuality>Normal</itemQuality>
        <isFighter>false</isFighter>
        <factionLeader>false</factionLeader>
        <apparelMoney>2500~3000</apparelMoney>
        <apparelTags>
            <li>Wolfein_starting</li>
        </apparelTags>
        <specificApparelRequirements>
            <li>
                <bodyPartGroup>Torso</bodyPartGroup>
                <requiredTag>Wolfein_starting</requiredTag>
            </li>
        </specificApparelRequirements>
        <apparelDisallowTags>
        </apparelDisallowTags>
        <apparelRequired>
        </apparelRequired>
        <apparelAllowHeadgearChance>0.5</apparelAllowHeadgearChance>
        <weaponTags>
        </weaponTags>
        <backstoryFiltersOverride>
            <li>
                <categoriesChildhood>
                    <li>Wolfein_ChildGeneral</li>
                </categoriesChildhood>
                <categoriesAdulthood>
                    <li>Wolfein_General</li>
                </categoriesAdulthood>
            </li>
        </backstoryFiltersOverride>
        <inventoryOptions>
            <subOptionsChooseOne>
                <li>
                    <choiceChance>100</choiceChance>
                    <thingDef>Silver</thingDef>
                    <countRange>
                        <min>25</min>
                        <max>80</max>
                    </countRange>
                </li>
            </subOptionsChooseOne>
        </inventoryOptions>
    </PawnKindDef>

