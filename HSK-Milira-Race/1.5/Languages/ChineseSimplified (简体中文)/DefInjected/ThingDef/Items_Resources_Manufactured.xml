<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN: Sunblast Furnace Core Model -->
  <Milira_FurnaceCoreModel.label>太阳熔炉炉心模型</Milira_FurnaceCoreModel.label>
  <!-- EN: A model of the core component of the Sunblast Furnace, through the study of this model, one can understand the construction method of the Sunblast Furnace. -->
  <Milira_FurnaceCoreModel.description>太阳熔炉核心组件的模型，通过研究该模型可以了解太阳熔炉的建造方法。</Milira_FurnaceCoreModel.description>
  <!-- EN: Reverse Engineering the Sunblast Furnace Core -->
  <Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.activateDescString>研究太阳熔炉炉心</Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.activateDescString>
  <!-- EN: Reverse -->
  <Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.activateLabelString>研究...</Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.activateLabelString>
  <!-- EN: By studying the Sunblast Furnace core, {PAWN_labelShort} have learned the method of constructing a Sunblast Furnace! Now we can assign colonists to research the construction and related technologies of the Sunblast Furnace. -->
  <Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.completedLetter>通过研究太阳熔炉炉心，{PAWN_labelShort} 已经知晓了太阳熔炉建造的方法！现在可以指派殖民者研究太阳熔炉的建造和相关科技了。</Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.completedLetter>
  <!-- EN: {RESEARCH} unlocked. -->
  <Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.completedLetterLabel>{RESEARCH} 已解锁</Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.completedLetterLabel>
  <!-- EN: Selecting Researchers for the Sunblast Furnace Core -->
  <Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.guiLabelString>选择由谁研究太阳熔炉炉心</Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.guiLabelString>
  <!-- EN: Capable of being researched by colonists -->
  <Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.inspectString>能够由殖民者研究</Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.inspectString>
  <!-- EN: Studying the Sunblast Furnace Core -->
  <Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.jobString>研究太阳熔炉炉心</Milira_FurnaceCoreModel.comps.CompAnalyzableUnlockResearch.jobString>
  
  <!-- EN: Milian power core -->
  <Milira_MilianReactor.label>米莉安动力炉心</Milira_MilianReactor.label>
  <!-- EN: The core power component of the Milian. -->
  <Milira_MilianReactor.description>米莉安的核心动力部件。</Milira_MilianReactor.description>
  
  <!-- EN: Resonator core -->
  <Milira_ResonatorCore.label>谐振子</Milira_ResonatorCore.label>
  <!-- EN: The core component of the resonator device. -->
  <Milira_ResonatorCore.description>谐振仪的核心部件。</Milira_ResonatorCore.description>
  
  <!-- EN: Solar Crystal -->
  <Milira_SolarCrystal.label>日凌晶</Milira_SolarCrystal.label>
  <!-- EN: The crystal that has undergone a change in properties due to excessive solar electromagnetic radiation. -->
  <Milira_SolarCrystal.description>在过量的太阳电磁辐射影响下产生了性质变化的水晶。</Milira_SolarCrystal.description>
  
  <!-- EN: Milira Starship Battery -->
  <Milira_StarshipBattery.label>米莉拉星舰电池</Milira_StarshipBattery.label>
  <!-- EN: A fuel cell with enough capacity to support the interstellar travel of a small spacecraft. When installed in a turret, it can provide an almost perpetual energy supply. -->
  <Milira_StarshipBattery.description>足以支撑一艘小型飞船星际航行的燃料电池，安装在炮台内可以维持近乎永久的能源供应。</Milira_StarshipBattery.description>
  
  <!-- EN: Solar Fuel -->
  <Milira_SunLightFuel.label>日光燃料</Milira_SunLightFuel.label>
