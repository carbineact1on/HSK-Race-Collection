<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- 无人机武器（无贴图） -->
    <ThingDef ParentName="BaseGun">
        <defName>W_Weapon_Drone</defName>
        <label>drone graser</label>
        <description>A low-powered laser gun mounted on the underside of the drone.</description>
        <tradeability>None</tradeability>
        <destroyOnDrop>true</destroyOnDrop>
        <relicChance>0</relicChance>
        <graphicData>
            <texPath>Wolfein/Empty</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <uiIconScale>1</uiIconScale>
        <uiIconPath>Wolfein/Weapon/DroneGraser</uiIconPath>
        <weaponClasses>
            <li>ShortShots</li>
        </weaponClasses>
        <weaponTags>
            <li>W_Weapon_Drone</li>
        </weaponTags>
        <statBases>
            <WorkToMake>11000</WorkToMake>
            <MarketValue>550</MarketValue>
            <Mass>2.5</Mass>
            <AccuracyTouch>0.90</AccuracyTouch>
            <AccuracyShort>0.75</AccuracyShort>
            <AccuracyMedium>0.55</AccuracyMedium>
            <AccuracyLong>0.15</AccuracyLong>
            <RangedWeapon_Cooldown>3.2</RangedWeapon_Cooldown>
        </statBases>
        <costList>
        </costList>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>W_ChargeBullet_Drone</defaultProjectile>
                <warmupTime>0.8</warmupTime>
                <range>18</range>
                <burstShotCount>1</burstShotCount>
                <ticksBetweenBurstShots>7</ticksBetweenBurstShots>
                <soundCast>Shot_MachinePistol</soundCast>
                <soundCastTail>GunTail_Light</soundCastTail>
                <muzzleFlashScale>9</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>5</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>
    <ThingDef ParentName="WolfeinBaseBullet">
        <defName>W_ChargeBullet_Drone</defName>
        <label>Wolfein Small Charge Bullet</label>
        <graphicData>
            <texPath>Wolfein/Weapon/RF_Bullet_effect</texPath>
