<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <RecipeDef Name="Wolfein_MechRecipeCivilBase" ParentName="BaseMechanoidRecipe" Abstract="True">
        <gestationCycles>2</gestationCycles>
    </RecipeDef>

    <RecipeDef Name="Wolfein_MechRecipe_CivilBase" ParentName="Wolfein_MechRecipeCivilBase">
        <defName>Wolfein_MechRecipe_CivilBase</defName>
        <label>Manufacture Basic Civilian Mech Unit</label>
        <description>Manufacture a Basic Civilian Mech Unit.</description>
        <researchPrerequisite>Wolfein_BasicCivilianMech</researchPrerequisite>
        <!-- HSK tuning: added Mechanism + Wolfein racial mech components for parity
             with the Military mech recipes (which use Wolfein_MechanicalComponent
             + Wolfein_ElectronicComponent). Civilian variant uses lower counts than
             military to reflect the simpler mech tier. -->
        <ingredients Inherit="False">
            <li>
                <filter>
                    <thingDefs>
                        <li>SteelBar</li>
                    </thingDefs>
                </filter>
                <count>24</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Plasteel</li>
                    </thingDefs>
                </filter>
                <count>20</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>ComponentIndustrial</li>
                    </thingDefs>
                </filter>
                <count>5</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Mechanism</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Wolfein_MechanicalComponent</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Wolfein_ElectronicComponent</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <products>
            <Wolfein_Mechanoid_CivilBase>1</Wolfein_Mechanoid_CivilBase>
        </products>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_Mechanoid_CivilBase</ThingDef>
        </descriptionHyperlinks>
    </RecipeDef>

    <RecipeDef Name="Wolfein_MechRecipe_CivilA" ParentName="Wolfein_MechRecipe_CivilBase">
        <defName>Wolfein_MechRecipe_CivilA</defName>
        <label>Manufacture Construction-Type Civilian Mech Unit</label>
        <description>Manufacture a Construction-Type Civilian Mech Unit.</description>
        <researchPrerequisite>Wolfein_CivilianUtilityMech</researchPrerequisite>
        <!-- HSK tuning: more Mechanism (utility mechs are smarter) + same Wolfein
             racial components as basic civilian. -->
        <ingredients Inherit="False">
            <li>
                <filter>
                    <thingDefs>
                        <li>SteelBar</li>
                    </thingDefs>
                </filter>
                <count>40</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Plasteel</li>
                    </thingDefs>
                </filter>
                <count>20</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>ComponentIndustrial</li>
                    </thingDefs>
                </filter>
                <count>8</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Mechanism</li>
                    </thingDefs>
                </filter>
                <count>2</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Wolfein_MechanicalComponent</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Wolfein_ElectronicComponent</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <products Inherit="False">
            <Wolfein_Mechanoid_CivilA>1</Wolfein_Mechanoid_CivilA>
        </products>
        <descriptionHyperlinks Inherit="False">
            <ThingDef>Wolfein_Mechanoid_CivilA</ThingDef>
        </descriptionHyperlinks>
    </RecipeDef>
    <RecipeDef ParentName="Wolfein_MechRecipe_CivilA">
        <defName>Wolfein_MechRecipe_CivilB</defName>
        <label>Manufacture Domestic-Type Civilian Mech Unit</label>
        <description>Manufacture a Domestic-Type Civilian Mech Unit.</description>
        <researchPrerequisite>Wolfein_CivilianUtilityMech</researchPrerequisite>
        <products Inherit="False">
            <Wolfein_Mechanoid_CivilB>1</Wolfein_Mechanoid_CivilB>
        </products>
        <descriptionHyperlinks Inherit="False">
            <ThingDef>Wolfein_Mechanoid_CivilB</ThingDef>
        </descriptionHyperlinks>
    </RecipeDef>
    <RecipeDef ParentName="Wolfein_MechRecipe_CivilA">
        <defName>Wolfein_MechRecipe_CivilC</defName>
        <label>Manufacture Agricultural-Type Civilian Mech Unit</label>
        <description>Manufacture an Agricultural-Type Civilian Mech Unit.</description>
        <researchPrerequisite>Wolfein_CivilianUtilityMech</researchPrerequisite>
        <products Inherit="False">
            <Wolfein_Mechanoid_CivilC>1</Wolfein_Mechanoid_CivilC>
        </products>
        <descriptionHyperlinks Inherit="False">
            <ThingDef>Wolfein_Mechanoid_CivilC</ThingDef>
        </descriptionHyperlinks>
    </RecipeDef>


</Defs>