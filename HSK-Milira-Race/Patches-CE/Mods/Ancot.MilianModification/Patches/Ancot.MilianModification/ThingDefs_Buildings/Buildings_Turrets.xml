<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <!-- Milian_SmallCloseInTurretUnit -->

    <Operation Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="Milian_SmallCloseInTurretUnit"]/thingClass</xpath>
        <value>
            <thingClass>CombatExtended.Building_TurretGunCE</thingClass>
        </value>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="Milian_SmallCloseInTurretUnit"]/statBases</xpath>
        <value>
            <Bulk>15</Bulk>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="Milian_SmallCloseInTurretUnit"]/statBases/ShootingAccuracyTurret</xpath>
        <value>
            <ShootingAccuracyTurret>1.00</ShootingAccuracyTurret>
            <AimingAccuracy>0.50</AimingAccuracy>
        </value>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>/Defs/ThingDef[defName="Milian_SmallCloseInTurretUnit"]/comps/li[@Class="CompProperties_Refuelable"]</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>/Defs/ThingDef[defName="Milian_SmallCloseInTurretUnit"]/placeWorkers/li[.="PlaceWorker_ShowTurretRadius"]</xpath>
    </Operation>
<!-- Operation Class="PatchOperationReplace"> -->

    <Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
        <defName>MilianTurretGun_SmallCloseInTurretUnit</defName>
        <statBases>
            <Bulk>12</Bulk>
            <SightsEfficiency>1.2</SightsEfficiency>
            <ShotSpread>0.063</ShotSpread>
            <SwayFactor>0.7</SwayFactor>
        </statBases>
        <Properties>
            <verbClass>CombatExtended.Verb_ShootCE</verbClass>
            <defaultProjectile>Bullet_762x51mmNATO_FMJ</defaultProjectile>
            <warmupTime>0.3</warmupTime>
            <recoilAmount>1</recoilAmount>
            <range>30</range>
            <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
            <burstShotCount>12</burstShotCount>
            <soundCast>Shot_Minigun</soundCast>
            <soundCastTail>GunTail_Heavy</soundCastTail>
            <muzzleFlashScale>6</muzzleFlashScale>
        </Properties>
        <AmmoUser>
            <magazineSize>120</magazineSize>
            <reloadTime>7.8</reloadTime>
            <ammoSet>AmmoSet_762x51mmNATO</ammoSet>
        </AmmoUser>
        <FireModes>
            <aiAimMode>AimedShot</aiAimMode>
            <noSnapshot>true</noSnapshot>
            <noSingleShot>true</noSingleShot>
        </FireModes>
    </Operation>

    <!-- Milian_FortressCIWS -->
    <!-- TODO: Add CE CIWS Ability -->

    <Operation Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="Milian_FortressCIWS"]/thingClass</xpath>
        <value>
            <thingClass>MilianModificationCE.Building_TurretGunCE_Fortress_CIWS</thingClass>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="Milian_FortressCIWS"]/fillPercent</xpath>
        <value>
            <fillPercent>0.75</fillPercent>
        </value>
    </Operation>
<!-- Operation Class="PatchOperationReplace"> -->

    <Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
        <defName>MilianFortressGun_CIWS</defName>
        <statBases>
            <Bulk>96</Bulk>
            <SightsEfficiency>3</SightsEfficiency>
            <ShotSpread>0.02</ShotSpread>
            <SwayFactor>0.1</SwayFactor>
        </statBases>
        <Properties>
            <verbClass>MilianModificationCE.Verb_ShootCE_Fortress_CIWS</verbClass>
            <defaultProjectile>Bullet_MilianFortressGun_CIWS</defaultProjectile>
            <warmupTime>0.0</warmupTime>
            <recoilAmount>0</recoilAmount>
            <minRange>2.9</minRange>
            <range>60</range>
            <ticksBetweenBurstShots>4</ticksBetweenBurstShots>
            <requireLineOfSight>false</requireLineOfSight>
            <burstShotCount>12</burstShotCount>
            <soundCast>Shot_Minigun</soundCast>
            <soundCastTail>GunTail_Heavy</soundCastTail>
            <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
            <stopBurstWithoutLos>false</stopBurstWithoutLos>
            <soundAiming>Milira_HeavyPlasma_Aiming</soundAiming>
            <muzzleFlashScale>12</muzzleFlashScale>
            <ai_ProjectileLaunchingIgnoresMeleeThreats>true</ai_ProjectileLaunchingIgnoresMeleeThreats>
        </Properties>
        <FireModes>
            <aiAimMode>AimedShot</aiAimMode>
            <noSnapshot>true</noSnapshot>
            <noSingleShot>true</noSingleShot>
        </FireModes>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>/Defs/ThingDef[defName="MilianFortressGun_CIWS"]/verbs/li[verbClass="MilianModification.Verb_Shoot_FortressCIWS"]</xpath>
    </Operation>

    <!-- Milian_FortressPlasma -->

    <Operation Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="Milian_FortressPlasma"]/thingClass</xpath>
        <value>
            <thingClass>MilianModificationCE.Building_TurretGunCE_Fortress_Plasma</thingClass>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="Milian_FortressPlasma"]/fillPercent</xpath>
        <value>
            <fillPercent>0.75</fillPercent>
        </value>
    </Operation>
<!-- Operation Class="PatchOperationReplace"> -->

    <Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
        <defName>MilianFortressGun_HeavyPlasma_II</defName>
        <statBases>
            <Bulk>96</Bulk>
            <SightsEfficiency>2.5</SightsEfficiency>
            <ShotSpread>0.02</ShotSpread>
            <SwayFactor>0.1</SwayFactor>
        </statBases>
        <Properties>
            <verbClass>MilianModificationCE.Verb_ShootCE_Fortress_Plasma</verbClass>
            <defaultProjectile>Bullet_MilianFortressGun_HeavyPlasma_II</defaultProjectile>
            <warmupTime>1.6</warmupTime>
            <recoilAmount>0</recoilAmount>
            <minRange>4.9</minRange>
            <range>102</range>
            <ticksBetweenBurstShots>70</ticksBetweenBurstShots>
            <requireLineOfSight>false</requireLineOfSight>
            <burstShotCount>1</burstShotCount>
            <soundCast>Milira_Shot_HeavyMortar</soundCast>
            <soundCastTail>GunTail_Heavy</soundCastTail>
            <stopBurstWithoutLos>false</stopBurstWithoutLos>
            <soundAiming>Milira_HeavyPlasma_Aiming</soundAiming>
            <muzzleFlashScale>9</muzzleFlashScale>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
            </targetParams>
            <ai_AvoidFriendlyFireRadius>8</ai_AvoidFriendlyFireRadius>
            <ai_ProjectileLaunchingIgnoresMeleeThreats>true</ai_ProjectileLaunchingIgnoresMeleeThreats>
        </Properties>
        <FireModes>
            <aiAimMode>AimedShot</aiAimMode>
            <noSnapshot>true</noSnapshot>
            <aiUseBurstMode>false</aiUseBurstMode>
            <aimedBurstShotCount>1</aimedBurstShotCount>
        </FireModes>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>/Defs/ThingDef[defName="MilianFortressGun_HeavyPlasma_II"]/verbs/li[verbClass="MilianModification.Verb_Shoot_FortressPlasma"]</xpath>
    </Operation>
    <Operation Class="PatchOperationConditional">
        <xpath>/Defs/ThingDef[defName="MilianFortressGun_HeavyPlasma_II"]/comps</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/ThingDef[defName="MilianFortressGun_HeavyPlasma_II"]</xpath>
            <value>
                <comps />
            </value>
        </nomatch>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <!-- Optimizes speed of projectile with flyOverhead=true -->
        <xpath>/Defs/ThingDef[defName="MilianFortressGun_HeavyPlasma_II"]/comps</xpath>
        <value>
            <li Class="CombatExtended.CompProperties_Charges">
                <chargeSpeeds>
                    <li>20</li>
                    <li>30</li>
                    <li>40</li>
                    <li>50</li>
                    <li>60</li>
                    <li>70</li>
                    <li>80</li>
                    <li>90</li>
                    <li>100</li>
                    <li>110</li>
                    <li>120</li>
                    <li>130</li>
                    <li>140</li>
                    <li>150</li>
                </chargeSpeeds>
            </li>
        </value>
    </Operation>

</Patch>