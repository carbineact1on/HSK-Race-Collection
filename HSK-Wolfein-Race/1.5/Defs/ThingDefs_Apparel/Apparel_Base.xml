<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ThingDef Name="Wolfein_ApparelBase" ParentName="ApparelBase" Abstract="True">
        <pathCost>10</pathCost>
        <graphicData>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>1.0</drawSize>
            <drawOffset>(0,0,0)</drawOffset>
        </graphicData>
        <apparel>
            <useWornGraphicMask>true</useWornGraphicMask>
            <tags>
                <li>Royal</li>
                <li>RoyalTier5</li>
            </tags>
            <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
        </apparel>
        <statBases>
            <Flammability>0.4</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
        </statBases>
        <comps>
            <li Class="CompProperties_Forbiddable" />
            <li>
                <compClass>CompColorable</compClass>
            </li>
        </comps>
    </ThingDef>

    <!-- 裁缝台 -->
    <ThingDef Name="Wolfein_MakeableBase_Tailoring" ParentName="Wolfein_ApparelBase" Abstract="True">
        <recipeMaker>
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Tailor</effectWorking>
            <soundWorking>Recipe_Tailor</soundWorking>
            <!-- HSK fix: route to HSK's tailoring benches, NOT Wolfein's own
                 Wolfein_Electric_TailoringBench (hidden from architect via
                 HSK_Disable_WolfeinBenches.xml). Without this, every apparel
                 tier that doesn't locally override recipeUsers (III, CombatI,
                 CombatII, Work, AIPT across all 5 categories) was only
                 craftable at a bench players can no longer build -> the
                 recipes appeared in research but had nowhere to be made.
                 (User report: Lycanthropy 2026-05-24 — "can't find the
                 wolfein tailoring bench, tabs light up but it doesn't show up".) -->
            <recipeUsers>
                <li>ElectricTailoringBench</li>
                <li>HandTailoringBench</li>
            </recipeUsers>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
            <defaultIngredientFilter>
                <categories>
                    <li>Root</li>
                </categories>
                <disallowedThingDefs>
                    <li>Gold</li>
                    <li>Silver</li>
                    <li>Plasteel</li>
                    <li>Jade</li>
                    <li>Uranium</li>
                </disallowedThingDefs>
            </defaultIngredientFilter>
        </recipeMaker>
    </ThingDef>

    <!-- 机工台 -->
    <ThingDef Name="Wolfein_MakeableBase_Smithing" ParentName="Wolfein_MakeableBase_Tailoring" Abstract="True">
        <recipeMaker>
            <recipeUsers Inherit="false">
                <li>ElectricTailoringBench</li>
            </recipeUsers>
        </recipeMaker>
    </ThingDef>

</Defs>