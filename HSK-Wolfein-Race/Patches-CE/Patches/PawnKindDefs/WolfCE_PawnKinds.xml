<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!-- ========== 添加背包的tag =========== -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/AlienRace.ThingDef_AlienRace[defName="Wolfein_Race"]/alienRace/raceRestriction/whiteApparelList</xpath>
		<value>
				<li>CE_Apparel_Backpack</li>
				<li>CE_Apparel_TribalBackpack</li>
				<li>CE_Apparel_KidBackpack</li>
		</value>
	</Operation>


	<Operation Class="PatchOperationAdd">
		<xpath>
			Defs/PawnKindDef[
			defName="Wolfein_Colonist" or
			defName="Wolfein_OutlierWolf" or
			defName="Wolfein_MegaCorpCivilian" or
			defName="Wolfein_MegaCorpClerk" or
			defName="Wolfein_MegaCorpTrader" or
			defName="Wolfein_MegaCorpRegionalSupervisor" or
			defName="Wolfein_MegaCorpArmedClerk" or
			defName="Wolfein_MegaCorpGuard" or
			defName="Wolfein_MegaCorpHacker" or
			defName="Wolfein_MegaCorpScout" or
			defName="Wolfein_MegaCorpSniper" or
			defName="Wolfein_MegaCorpSupport"or
			defName="Wolfein_MegaCorpSupportInTrade"or
			defName="Wolfein_MegaCorpSurgeon"or
			defName="Wolfein_MegaCorpVanguard"or
			defName="Wolfein_RebelMelee"or
			defName="Wolfein_RebelScout"or
			defName="Wolfein_RebelSoldier"or
			defName="Wolfein_RebelSoldier_HeavyArmored"
			]/apparelTags
		</xpath>
		<value>
			<li>CE_Apparel_Backpack</li>
		</value>
	</Operation>


	<!-- ========== 殖民者 ========== -->
	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="Wolfein_Colonist"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<primaryMagazineCount>
					<min>10</min>
					<max>25</max>
				</primaryMagazineCount>
			</li>
		</value>
	</Operation>
	
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="Wolfein_Colonist"]/specificApparelRequirements</xpath>
		<value>
			<li>
				<bodyPartGroup>Shoulders</bodyPartGroup>
				<requiredTag>CE_Apparel_Backpack</requiredTag>
			</li>
		</value>
	</Operation>

	<!-- ========== 离群狼 ========== -->
	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="Wolfein_OutlierWolf"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<primaryMagazineCount>
					<min>2</min>
					<max>3</max>
				</primaryMagazineCount>
			</li>
		</value>
	</Operation>

    <!--军企一般平民-->
	<Operation Class="PatchOperationAddModExtension">
