<?xml version="1.0" encoding="utf-8" ?>
<!-- HSK material conversion for VRE Waster -->
<Patch>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_BurnBarrel"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>RuggedMetallic</li>
            </stuffCategories>
            <costStuffCount>45</costStuffCount>
            <costList>
                <ComponentIndustrial>1</ComponentIndustrial>
            </costList>
        </value>
    </Operation>

    <!-- Strip inherited constructEffect: madeFromStuff + constructEffect is a config error -->
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="VRE_BurnBarrel"]/constructEffect</xpath>
    </Operation>

</Patch>
