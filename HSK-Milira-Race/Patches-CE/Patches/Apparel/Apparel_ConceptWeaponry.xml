<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <!-- Milira_ConceptWeaponryBase -->

    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[@Name="Milira_ConceptWeaponryBase"]/statBases</xpath>
        <value>
            <Bulk>100</Bulk>
            <WornBulk>15</WornBulk>
        </value>
    </Operation>

    <!-- Milira_ConceptWeaponry_Cyclops -->

    <Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
        <defName>MiliraTurret_ConceptWeaponry_PlasmaCannon</defName>
        <statBases>
            <SightsEfficiency>1.1</SightsEfficiency>
            <ShotSpread>0.142</ShotSpread>
            <SwayFactor>1.8</SwayFactor>
        </statBases>
        <Properties>
            <verbClass>CombatExtended.Verb_ShootCE</verbClass>
            <defaultProjectile>Bullet_MiliraHeavyPlasmaCannon</defaultProjectile>
            <requireLineOfSight>true</requireLineOfSight>
            <range>72</range>
            <minRange>4.5</minRange>
            <soundCast>Milira_Shot_HeavyPlasma</soundCast>
            <soundCastTail>GunTail_Heavy</soundCastTail>
            <muzzleFlashScale>3</muzzleFlashScale>
            <defaultCooldownTime>8</defaultCooldownTime>
            <burstShotCount>1</burstShotCount>
            <ticksBetweenBurstShots>5</ticksBetweenBurstShots>
            <ai_AvoidFriendlyFireRadius>6</ai_AvoidFriendlyFireRadius>
        </Properties>
    </Operation>

</Patch>