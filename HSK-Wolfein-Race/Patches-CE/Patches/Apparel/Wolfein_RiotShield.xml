<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 防暴盾（固定材料） -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_RiotShield"]/statBases</xpath>
		<value>
			<Bulk>60</Bulk>
			<WornBulk>8</WornBulk>
			<StuffEffectMultiplierArmor>6</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Wolfein_RiotShield"]/statBases</xpath>
		<value>
		<statBases>
			<ArmorRating_Sharp>14.8</ArmorRating_Sharp>
			<ArmorRating_Blunt>24.5</ArmorRating_Blunt>
		</statBases>
		</value>
	</Operation>


  <Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Wolfein_RiotShield"]/equippedStatOffsets</xpath>
		<value>
		<equippedStatOffsets>
			<MoveSpeed>-0.3</MoveSpeed>
			<ReloadSpeed>-0.2</ReloadSpeed>
			<ShootingAccuracyPawn>-0.25</ShootingAccuracyPawn>
			<AimingAccuracy>-0.16</AimingAccuracy>
			<Suppressability>-0.50</Suppressability>
			<MeleeCritChance>-0.05</MeleeCritChance>
			<MeleeParryChance>0.8</MeleeParryChance>
			<MeleeHitChance>-0.5</MeleeHitChance>
		</equippedStatOffsets>
		</value>
	</Operation>


</Patch>
