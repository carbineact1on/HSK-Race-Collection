<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!--
		HSK fix part 1: turret BUILDINGS need Building_TurretGunCE thingClass.
		Without this, the turret aims correctly at targets but never fires —
		the vanilla Building_TurretGun class doesn't know how to consume CE
		ammo from its CompAmmoUser. Building_TurretGunCE handles the CE
		ammo loading + reload cycle.

		Wolfein_Turret_E (rocket turret) originally used a custom
		Wolfein.Building_TurretGunForceAiming class. Without
		Building_TurretGunCE it never consumes CE rocket ammo, so we
		swap it too. Forced-aim was just AI targeting behavior; CE's
		built-in turret class handles rocket-arc trajectories fine
		via the gun's own Verb_ShootCE projectile properties.
	-->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Wolfein_Turret_A"]/thingClass</xpath>
		<value>
			<thingClass>CombatExtended.Building_TurretGunCE</thingClass>
		</value>
	</Operation>

	<!-- Wolfein_Turret_B inherits thingClass from Wolfein_Turret_A (above),
	     so its locally-undefined <thingClass> can't be xpath-replaced.
	     The CE thingClass propagates via ParentName inheritance. -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Wolfein_Turret_D"]/thingClass</xpath>
		<value>
			<thingClass>CombatExtended.Building_TurretGunCE</thingClass>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Wolfein_Turret_E"]/thingClass</xpath>
		<value>
			<thingClass>CombatExtended.Building_TurretGunCE</thingClass>
		</value>
	</Operation>

	<!--
		HSK fix part 2: full CE patches for all 4 Wolfein turret guns.
		The original file was empty (just a comment header), so under CE
		the turrets had no Verb_ShootCE / AmmoUser / proper CE projectile
		bindings — they would fall back to vanilla verb behavior and
		ignore the CE ammo system.

		Calibers picked from HSK-CE-active set (since HSK disables many
		CE calibers via .xml.bak):
		  - Turret A (heavy sentry rifle, single shot)  -> 7.62x51mm NATO
		  - Turret B (rapid-fire LMG, 8-shot burst)      -> 5.56x45mm NATO
		  - Turret D (twin autocannon, 40-shot burst)    -> .50 BMG
		  - Turret E (rocket launcher, 6-shot, range 52) -> RPG-7

		Note: only Turret_A and Turret_D are buildable from architect.
		Turret_B and Turret_E are architect-hidden and only spawn at
		MegaCorp settlements/raids. Patching all 4 ensures enemy-spawned
		turrets fire correctly under CE too.
	-->

	<!-- ========== Turret A — Heavy Sentry Rifle (7.62x51mm NATO) ========== -->
	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>Wolfein_TurretGun_A</defName>
		<statBases>
			<RangedWeapon_Cooldown>1.8</RangedWeapon_Cooldown>
			<SightsEfficiency>1.0</SightsEfficiency>
			<ShotSpread>0.06</ShotSpread>
			<SwayFactor>0.85</SwayFactor>
			<Bulk>14.0</Bulk>
			<AimingAccuracy>0.85</AimingAccuracy>
		</statBases>
		<Properties>
			<recoilAmount>0.7</recoilAmount>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<defaultProjectile>Bullet_762x51mmNATO_FMJ</defaultProjectile>
			<warmupTime>0.6</warmupTime>
			<range>40</range>
			<burstShotCount>1</burstShotCount>
			<ticksBetweenBurstShots>0</ticksBetweenBurstShots>
			<soundCast>Shot_Autocannon</soundCast>
			<soundCastTail>GunTail_Heavy</soundCastTail>
			<muzzleFlashScale>10</muzzleFlashScale>
			<recoilPattern>Mounted</recoilPattern>
		</Properties>
		<AmmoUser>
			<magazineSize>30</magazineSize>
			<reloadTime>5.0</reloadTime>
			<ammoSet>AmmoSet_762x51mmNATO</ammoSet>
		</AmmoUser>
		<FireModes>
			<aiAimMode>AimedShot</aiAimMode>
			<noSnapshot>true</noSnapshot>
		</FireModes>
	</Operation>

	<!-- ========== Turret B — Rapid-Fire LMG (7.62x39mm Soviet, long burst + cooldown) ==========
	     User intent: long sustained burst (no mid-burst cooldown), then a
	     proper "cooling off" gap before the next burst — barrel needs to
	     cool down between trigger pulls. ~2s of continuous fire, then
	     ~2s cooldown, repeat until mag empty.
	     Caliber bumped from 5.56 NATO to 7.62x39mm Soviet so the heavier
	     ammo logistics balance the sustained DPS (PKM/RPK feel). -->
	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>Wolfein_TurretGun_B</defName>
		<statBases>
			<RangedWeapon_Cooldown>0.8</RangedWeapon_Cooldown>
			<SightsEfficiency>0.95</SightsEfficiency>
			<ShotSpread>0.08</ShotSpread>
			<SwayFactor>1.1</SwayFactor>
			<Bulk>10.0</Bulk>
			<AimingAccuracy>0.75</AimingAccuracy>
		</statBases>
		<Properties>
			<recoilAmount>0.5</recoilAmount>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<defaultProjectile>Bullet_762x39mmSoviet_FMJ</defaultProjectile>
			<warmupTime>0.6</warmupTime>
			<range>35</range>
			<burstShotCount>20</burstShotCount>
			<ticksBetweenBurstShots>3</ticksBetweenBurstShots>
			<soundCast>GunShotA</soundCast>
			<soundCastTail>GunTail_Light</soundCastTail>
			<muzzleFlashScale>9</muzzleFlashScale>
			<recoilPattern>Mounted</recoilPattern>
		</Properties>
		<AmmoUser>
			<magazineSize>120</magazineSize>
			<reloadTime>12.0</reloadTime>
			<ammoSet>AmmoSet_762x39mmSoviet</ammoSet>
		</AmmoUser>
		<FireModes>
			<aiAimMode>SuppressFire</aiAimMode>
			<noSingleShot>true</noSingleShot>
		</FireModes>
	</Operation>

	<!-- ========== Turret D — Twin Autocannon (.50 BMG) ========== -->
	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>Wolfein_TurretGun_D</defName>
		<statBases>
			<RangedWeapon_Cooldown>0.6</RangedWeapon_Cooldown>
			<SightsEfficiency>1.05</SightsEfficiency>
			<ShotSpread>0.07</ShotSpread>
			<SwayFactor>1.3</SwayFactor>
			<Bulk>22.0</Bulk>
			<AimingAccuracy>0.85</AimingAccuracy>
		</statBases>
		<Properties>
			<recoilAmount>0.6</recoilAmount>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<defaultProjectile>Bullet_50BMG_FMJ</defaultProjectile>
			<warmupTime>1.0</warmupTime>
			<range>42</range>
			<burstShotCount>40</burstShotCount>
			<ticksBetweenBurstShots>3</ticksBetweenBurstShots>
			<soundCast>Shot_Autocannon</soundCast>
			<soundCastTail>GunTail_Heavy</soundCastTail>
			<muzzleFlashScale>14</muzzleFlashScale>
			<recoilPattern>Mounted</recoilPattern>
		</Properties>
		<AmmoUser>
			<magazineSize>120</magazineSize>
			<reloadTime>10.5</reloadTime>
			<ammoSet>AmmoSet_50BMG</ammoSet>
		</AmmoUser>
		<FireModes>
			<aiAimMode>SuppressFire</aiAimMode>
			<noSnapshot>true</noSnapshot>
			<noSingleShot>true</noSingleShot>
		</FireModes>
	</Operation>

	<!-- ========== Turret E — Rocket Launcher (RPG-7) ========== -->
	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>Wolfein_TurretGun_E</defName>
		<statBases>
			<RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
			<SightsEfficiency>1.0</SightsEfficiency>
			<ShotSpread>0.10</ShotSpread>
			<SwayFactor>1.5</SwayFactor>
			<Bulk>18.0</Bulk>
			<AimingAccuracy>0.85</AimingAccuracy>
		</statBases>
		<!--
			DIRECT-FIRE rocket turret (NOT a mortar).
			The original Wolfein_TurretGun_E used vanilla Verb_Shoot (a
			line-of-sight rocket launcher with location targeting). An earlier
			revision of this patch converted it to Verb_ShootMortarCE (indirect
			mortar), but HSK Core's startup turret check (SK.Controller.ErrorCheck)
			only accepts Verb_ShootCE / Verb_Shoot / Verb_Spray-derived verbs and
			warns that a mortar-verb turret "will throw NRE when trying to replace"
			it — a real risk since Wolfein_Turret_E spawns in MegaCorp raids.
			Verb_ShootCE is the faithful CE equivalent of the original Verb_Shoot
			and passes HSK's check, so we use it. (User report: Vladimir Lash 2026-05.) -->
		<Properties>
			<recoilAmount>1.0</recoilAmount>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<defaultProjectile>Bullet_130mmRocketMissile</defaultProjectile>
			<warmupTime>1.5</warmupTime>
			<range>50</range>
			<burstShotCount>1</burstShotCount>
			<soundCast>130mmRocket</soundCast>
			<soundCastTail>GunTail_Heavy</soundCastTail>
			<muzzleFlashScale>16</muzzleFlashScale>
			<recoilPattern>Mounted</recoilPattern>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetPawns>true</canTargetPawns>
				<canTargetBuildings>true</canTargetBuildings>
			</targetParams>
		</Properties>
		<AmmoUser>
			<magazineSize>6</magazineSize>
			<reloadTime>15.0</reloadTime>
			<ammoSet>AmmoSet_130mmRocketMissile</ammoSet>
		</AmmoUser>
		<FireModes>
			<aiAimMode>AimedShot</aiAimMode>
		</FireModes>
	</Operation>

	<!-- (CompProperties_Charges removed — charge-speed ranging is a mortar-only
	     mechanic; this is now a direct-fire turret.) -->

	<!-- Quicker fire cadence: override the Wolfein turret base's
	     turretBurstCooldownTime (30s in original def) and warmup (4s)
	     for a snappier rocket turret feel. -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Wolfein_Turret_E"]/building/turretBurstCooldownTime</xpath>
		<value>
			<turretBurstCooldownTime>2</turretBurstCooldownTime>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Wolfein_Turret_E"]/building/turretBurstWarmupTime</xpath>
		<value>
			<turretBurstWarmupTime>0.5</turretBurstWarmupTime>
		</value>
	</Operation>

	<!-- Remove the turret BUILDING's Refuelable (barrel durability) comp.
	     The barrel-durability/fuel system fights CE's ammo flow on a turret
	     gun and was a likely silent-fail cause; CE's own turret patches drop
	     it too. -->
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="Wolfein_Turret_E"]/comps/li[@Class="CompProperties_Refuelable"]</xpath>
	</Operation>

	<!-- NOTE: no placeWorkers override needed. An earlier revision added a
	     placeWorkers list with Inherit="False" (dropping PlaceWorker_TurretTop)
	     to dodge a mortar-verb NRE. Now that the gun is direct-fire Verb_ShootCE,
	     the inherited turret placeWorkers [PlaceWorker_TurretTop,
	     PlaceWorker_ShowTurretRadius] from Wolfein_Turret_D are correct again,
	     so we let them inherit normally. The root cause (mortar verbClass) is
	     fixed above; HSK Core's turret check now passes. -->

</Patch>
