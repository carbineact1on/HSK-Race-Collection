<?xml version="1.0" encoding="utf-8" ?>
<!--
    HSK + Combat Extended patches for VRE Sanguophage.

    Two categories of changes:

    1. HSK material conversion on 6 deathrest/hemogen buildings:
       - Steel → SteelBar (refined alloy used by HSK construction)
       - Gold  → GoldBar  (refined alloy on InvocationMatrix)
       Plasteel kept as-is (already HSK-native).

    2. CE patch on the SharpTalons hediff (granted by the SharpTalons gene
       to Sanguophages and other talon-bearing xenotypes):
       - Vanilla tool: power 16, cooldown 2.0, capacity Cut, no AP fields
       - Converted to CombatExtended.ToolCE with armor-penetration values
         comparable to other natural-claw conversions in HSK Race Collection
         (Saurid claws have AP-Sharp 0.5 / Blunt 2 — talons are sharper so
         we bump AP-Sharp to 0.65 to reflect the "deep cut" narrative)

    Goo projectile (VRE_Proj_Goo) already has armorPenetrationBase/stoppingPower
    and uses the Stun damageDef — works under CE without explicit conversion.
    Hemogen abilities are psycaster-style (no projectiles to convert).
    HemogenPack items are food (no costList to swap, no Bulk addition needed
    since they're a Fluid/DesperateOnly food consumed off the inventory).
-->
<Patch>

    <!-- ============================================================ -->
    <!--  HSK MATERIAL CONVERSION — Deathrest / Hemogen buildings    -->
    <!-- ============================================================ -->

    <!-- VRE_InvocationMatrix — Steel + Gold -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_InvocationMatrix"]/costList/Steel</xpath>
        <value><SteelBar>120</SteelBar></value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_InvocationMatrix"]/costList/Gold</xpath>
        <value><GoldBar>40</GoldBar></value>
    </Operation>

    <!-- VRE_HemodynamicAccelerator — Steel only -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemodynamicAccelerator"]/costList/Steel</xpath>
        <value><SteelBar>450</SteelBar></value>
    </Operation>

    <!-- VRE_HemogenSolidifier — Steel only -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_HemogenSolidifier"]/costList/Steel</xpath>
        <value><SteelBar>250</SteelBar></value>
    </Operation>

    <!-- VRE_SmallHemogenAmplifier — Steel only -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_SmallHemogenAmplifier"]/costList/Steel</xpath>
        <value><SteelBar>100</SteelBar></value>
    </Operation>

    <!-- VRE_SmallHemopump — Steel only -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_SmallHemopump"]/costList/Steel</xpath>
        <value><SteelBar>50</SteelBar></value>
    </Operation>

    <!-- VRE_PsychofluidWell (Royalty DLC only) — Steel + Plasteel -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Royalty</li>
        </mods>
        <match Class="PatchOperationReplace">
            <xpath>Defs/ThingDef[defName="VRE_PsychofluidWell"]/costList/Steel</xpath>
            <value><SteelBar>100</SteelBar></value>
        </match>
    </Operation>

    <!-- ============================================================ -->
    <!--  CE PATCH — SharpTalons hediff to ToolCE                     -->
    <!-- ============================================================ -->

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/HediffDef[defName="VRE_SharpTalons"]/comps/li[@Class="HediffCompProperties_VerbGiver"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>talons</label>
                    <capacities>
                        <li>Cut</li>
                    </capacities>
                    <power>16</power>
                    <cooldownTime>2</cooldownTime>
                    <armorPenetrationSharp>0.65</armorPenetrationSharp>
                    <armorPenetrationBlunt>2</armorPenetrationBlunt>
                </li>
            </tools>
        </value>
    </Operation>

</Patch>
