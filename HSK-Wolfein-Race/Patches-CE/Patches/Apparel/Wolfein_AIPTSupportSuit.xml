<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 沃芬族AIPT处理组支援服（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_AIPTSupportSuit"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>350</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>2.5</Mass>
            <EquipDelay>1.5</EquipDelay>
            <WorkToMake>18500</WorkToMake>
            <Insulation_Cold>12.5</Insulation_Cold>
            <Insulation_Heat>12.3</Insulation_Heat>
            <ArmorRating_Sharp>4</ArmorRating_Sharp>
            <ArmorRating_Blunt>2</ArmorRating_Blunt>
            <ArmorRating_Heat>0.15</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>1</Bulk>
            <WornBulk>3.5</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_AIPTSupportSuit"]/equippedStatOffsets</xpath>
		<value>
      <CarryBulk>15</CarryBulk>
      <CarryWeight>21</CarryWeight>
		</value>
	</Operation>

</Patch>
