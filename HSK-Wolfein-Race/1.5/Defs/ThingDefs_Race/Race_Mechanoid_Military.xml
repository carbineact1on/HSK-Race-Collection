    <!-- 盾卫型军用机械体 -->
    <ThingDef ParentName="Wolfein_BaseMechMilitary">
        <defName>Wolfein_Mechanoid_MilitaryC</defName>
        <label>Shielded Military Mech Unit</label>
        <description>Equipped with a heavy shield and an impact drill, this unit excels at close-range encounters with heavily armored mech targets. Its drill's exceptional destructive power against structures also makes it a frequent choice for demolition operations.</description>
        <tools>
            <li Class="CombatExtended.ToolCE">
                <label>Heavy shield</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>15</power>
                <cooldownTime>2.0</cooldownTime>
                <linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
                <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
                <armorPenetrationBlunt>0.75</armorPenetrationBlunt>
            </li>
            <li Class="CombatExtended.ToolCE">
                <label>Impact drill</label>
                <capacities>
                    <li>Demolish</li>
                </capacities>
                <power>28.0</power>
                <cooldownTime>2.0</cooldownTime>
                <linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
                <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
                <armorPenetrationBlunt>1.5</armorPenetrationBlunt>
            </li>
        </tools>
        <race>
            <baseHealthScale>2.0</baseHealthScale>
        </race>
        <statBases>
            <IncomingDamageFactor>0.8</IncomingDamageFactor>
            <ArmorRating_Blunt>0.5</ArmorRating_Blunt>
            <ArmorRating_Sharp>0.8</ArmorRating_Sharp>
        </statBases>
    </ThingDef>
