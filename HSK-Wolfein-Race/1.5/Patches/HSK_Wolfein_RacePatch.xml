	<!--pawnkind-->
	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>Defs/PawnKindDef[@Name="Wolfein_PawnBase"]/xenotypeSet</xpath>
				<value>
					<xenotypeSet>
						<xenotypeChances>
							<Wolfein_Xenotype MayRequire="Ludeon.RimWorld.Biotech">0.95</Wolfein_Xenotype>
							<Wolfein_Xenotype_PureBlood MayRequire="Ludeon.RimWorld.Biotech">0.05</Wolfein_Xenotype_PureBlood>
						</xenotypeChances>
					</xenotypeSet>
				</value>
			</li>
		</operations>
	</Operation>

	<!-- 种族 -->
	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>Defs/AlienRace.ThingDef_AlienRace[defName="Wolfein_Race"]/alienRace/raceRestriction/xenotypeList</xpath>
				<value>
					<xenotypeList MayRequire="Ludeon.RimWorld.Biotech">
						<li MayRequire="Ludeon.RimWorld.Biotech">Wolfein_Xenotype</li>
						<li MayRequire="Ludeon.RimWorld.Biotech">Wolfein_Xenotype_PureBlood</li>
					</xenotypeList>
				</value>
			</li>
