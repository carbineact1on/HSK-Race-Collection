<?xml version="1.0" encoding="utf-8" ?>
<!--
    HSK + Combat Extended patches for VRE Insector.

    Three categories of changes:

    1. CE TOOL CONVERSION (4 hediffs that grant insectoid melee weapons)
       - VRE_InsectMandibles  → ToolCE Cut, Sharp 0.5 / Blunt 2.0
       - VRE_HornAttack       → ToolCE Stab, Sharp 0.4 / Blunt 2.5
       - VRE_RipperBlades     → ToolCE Cut, Sharp 0.7 / Blunt 1.5
                                (had vanilla armorPenetration 0.27 — split into
                                 CE Sharp/Blunt with sharpness boost since the
                                 description specifies armor-rending blades)
       - VRE_InsectRostrum    → ToolCE Stab, Sharp 0.6 / Blunt 2.0
                                (cross-mod — VFE Insectoid 2 conditional)

    2. HSK CE ARMOR RESCALE (2 genes / hediffs with armor stat offsets)
       - VRE_Insectskin gene: Sharp 0.27/Blunt 0.18 (vanilla CE) →
                              Sharp 4 / Blunt 4 (HSK CE basic carapace tier,
                              comparable to Saurid scaleskin)
       - VRE_MineralRichInsectskin (cross-mod, 2 health stages):
                              stage 0.1: 0.48/0.26 → 6/4   (low-health, cracked)
                              stage 1:   0.9/0.52 → 12/8   (full-health, between flak and marine)

    3. HSK MATERIAL — VRE_InfestedShipPart_Spawned costList
       Steel 20 → SteelBar 20 (small chunk loot building)

    No work needed for:
      - VRE_AcidBurstSack / VRE_ChemfuelSacks — use AnimalBehaviours.
        HediffCompProperties_ExplodeOnDamage / Exploder which are
        custom-class hediff comps that work under CE without conversion
      - Insector abilities (psycaster-style, no projectiles)
      - VRE_Metapod / MetapodSickness (cocoon mechanics, no combat)
-->
<Patch>

    <!-- ============================================================ -->
    <!--  CE TOOL CONVERSION (insectoid melee hediffs)               -->
    <!-- ============================================================ -->

    <!-- VRE_InsectMandibles -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/HediffDef[defName="VRE_InsectMandibles"]/comps/li[@Class="HediffCompProperties_VerbGiver"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>insect mandibles</label>
                    <capacities>
                        <li>Cut</li>
                    </capacities>
                    <power>24</power>
                    <cooldownTime>3.2</cooldownTime>
                    <armorPenetrationSharp>0.5</armorPenetrationSharp>
                    <armorPenetrationBlunt>2</armorPenetrationBlunt>
                    <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
                </li>
            </tools>
        </value>
    </Operation>

    <!-- VRE_HornAttack (megaspider horns) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/HediffDef[defName="VRE_HornAttack"]/comps/li[@Class="HediffCompProperties_VerbGiver"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>megaspider horns</label>
                    <capacities>
                        <li>Stab</li>
                    </capacities>
                    <power>16</power>
                    <cooldownTime>2</cooldownTime>
                    <armorPenetrationSharp>0.4</armorPenetrationSharp>
                    <armorPenetrationBlunt>2.5</armorPenetrationBlunt>
                </li>
            </tools>
        </value>
    </Operation>

    <!-- VRE_RipperBlades (armor-rending) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/HediffDef[defName="VRE_RipperBlades"]/comps/li[@Class="HediffCompProperties_VerbGiver"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>ripper-blade</label>
                    <capacities>
                        <li>Cut</li>
                    </capacities>
                    <power>18</power>
                    <cooldownTime>2</cooldownTime>
                    <armorPenetrationSharp>0.7</armorPenetrationSharp>
                    <armorPenetrationBlunt>1.5</armorPenetrationBlunt>
                </li>
            </tools>
        </value>
    </Operation>

    <!-- VRE_InsectRostrum (cross-mod, only fires if VFE Insectoid 2 active) -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>OskarPotocki.VFE.Insectoid2</li>
        </mods>
        <match Class="PatchOperationReplace">
            <xpath>Defs/HediffDef[defName="VRE_InsectRostrum"]/comps/li[@Class="HediffCompProperties_VerbGiver"]/tools</xpath>
            <value>
                <tools>
                    <li Class="CombatExtended.ToolCE">
                        <label>insect rostrum</label>
                        <capacities>
                            <li>Stab</li>
                        </capacities>
                        <power>24</power>
                        <cooldownTime>2.8</cooldownTime>
                        <armorPenetrationSharp>0.6</armorPenetrationSharp>
                        <armorPenetrationBlunt>2</armorPenetrationBlunt>
                        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
                    </li>
                </tools>
            </value>
        </match>
    </Operation>

    <!-- ============================================================ -->
    <!--  HSK CE ARMOR RESCALE                                        -->
    <!-- ============================================================ -->

    <!-- VRE_Insectskin gene — basic carapace -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/GeneDef[defName="VRE_Insectskin"]/statOffsets</xpath>
        <value>
            <statOffsets>
                <ArmorRating_Sharp>4</ArmorRating_Sharp>
                <ArmorRating_Blunt>4</ArmorRating_Blunt>
            </statOffsets>
        </value>
    </Operation>

    <!-- VRE_MineralRichInsectskin hediff — armored insectskin (2 stages, cross-mod) -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>OskarPotocki.VFE.Insectoid2</li>
        </mods>
        <match Class="PatchOperationReplace">
            <xpath>Defs/HediffDef[defName="VRE_MineralRichInsectskin"]/stages</xpath>
            <value>
                <stages>
                    <li>
                        <minSeverity>0.1</minSeverity>
                        <statOffsets>
                            <ArmorRating_Sharp>6</ArmorRating_Sharp>
                            <ArmorRating_Blunt>4</ArmorRating_Blunt>
                        </statOffsets>
                    </li>
                    <li>
                        <minSeverity>1</minSeverity>
                        <statOffsets>
                            <ArmorRating_Sharp>12</ArmorRating_Sharp>
                            <ArmorRating_Blunt>8</ArmorRating_Blunt>
                        </statOffsets>
                    </li>
                </stages>
            </value>
        </match>
    </Operation>

    <!-- ============================================================ -->
    <!--  HSK MATERIAL CONVERSION + ship chunk rebalance              -->
    <!-- ============================================================ -->

    <!-- VRE_InfestedShipPart_Spawned — bump to ~50% of HSK vanilla
         ShipChunk's deconstruct yield. Upstream value was ~37% of HSK
         ShipChunk (Steel 20 + CompInd 6 vs HSK's Plasteel 35 + Wire 15 +
         CompInd 15 + CompSpacer 3 + Mechanism 3). Lore: still less
         valuable than clean ship debris because of insectoid biomass
         takeover, but no longer 3x cheaper than what HSK colonies expect. -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VRE_InfestedShipPart_Spawned"]/costList</xpath>
        <value>
            <costList>
                <SteelBar>30</SteelBar>
                <ComponentIndustrial>8</ComponentIndustrial>
                <Wire>8</Wire>
                <InsectJelly>5</InsectJelly>
            </costList>
        </value>
    </Operation>

</Patch>
