<?xml version="1.0" encoding="utf-8" ?>
<!-- HSK fix: add CombatExtended compatibility comps to Wolfein mech bases -->
<Patch>

    <!-- HSK: ammo comps go ONLY on the combat-mech base (Wolfein_BaseMechMilitary).
         Putting them on the shared Wolfein_BaseMech made the Light recon DRONES + civil mechs
         inherit a ticking CompMechAmmo they can't service -> per-tick NRE + massive TPS loss
         (dadarard report 2026-06). Drones/civil revert to their pre-fix state. -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[@Name="Wolfein_BaseMechMilitary"]/comps</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[@Name="Wolfein_BaseMechMilitary"]</xpath>
            <value>
                <comps />
            </value>
        </nomatch>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[@Name="Wolfein_BaseMechMilitary"]/comps</xpath>
        <value>
            <li>
                <compClass>CombatExtended.CompPawnGizmo</compClass>
            </li>
            <li>
                <compClass>CombatExtended.CompAmmoGiver</compClass>
            </li>
            <li Class="CombatExtended.CompProperties_Inventory" />
            <li Class="CombatExtended.CompProperties_MechAmmo">
                <gizmoIconSetMagCount>UI/Buttons/SetMagCount</gizmoIconSetMagCount>
                <gizmoIconTakeAmmoNow>UI/Buttons/TakeAmmoNow</gizmoIconTakeAmmoNow>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[@Name="Wolfein_BaseMech"]/statBases</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[@Name="Wolfein_BaseMech"]</xpath>
            <value>
                <statBases />
            </value>
        </nomatch>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[@Name="Wolfein_BaseMech"]/statBases</xpath>
        <value>
            <SmokeSensitivity>0</SmokeSensitivity>
            <NightVisionEfficiency>0.80</NightVisionEfficiency>
        </value>
    </Operation>

<!-- HSK CE convention: mechanoid sensor parts (SightSensor / HearingSensor / -->
    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[@Name="Wolfein_BaseMech"]</xpath>
        <value>
            <li Class="CombatExtended.PartialArmorExt">
                <stats>
                    <li>
                        <ArmorRating_Sharp>0.25</ArmorRating_Sharp>
                        <parts>
                            <li>SightSensor</li>
                            <li>HearingSensor</li>
                            <li>SmellSensor</li>
                        </parts>
                    </li>
                    <li>
                        <ArmorRating_Blunt>0.25</ArmorRating_Blunt>
                        <parts>
                            <li>SightSensor</li>
                            <li>HearingSensor</li>
                            <li>SmellSensor</li>
                        </parts>
                    </li>
                </stats>
            </li>
        </value>
    </Operation>

</Patch>
