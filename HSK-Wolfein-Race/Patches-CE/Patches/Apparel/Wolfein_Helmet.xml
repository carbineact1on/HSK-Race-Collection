            <WorkToMake>16500</WorkToMake>
            <ArmorRating_Sharp>9</ArmorRating_Sharp>
            <ArmorRating_Blunt>14</ArmorRating_Blunt>
            <Bulk>4</Bulk>
            <WornBulk>1</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

</Patch>
