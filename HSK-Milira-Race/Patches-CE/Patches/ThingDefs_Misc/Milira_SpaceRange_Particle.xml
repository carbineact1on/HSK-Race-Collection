                    <soundCastTail>GunTail_Heavy</soundCastTail>
                    <muzzleFlashScale>6</muzzleFlashScale>
                    <ai_AvoidFriendlyFireRadius>4</ai_AvoidFriendlyFireRadius>
                </verbPropsUnderBarrel>
                <propsUnderBarrel Class="MiliraCE.CompProperties_AmmoUserChargable">
                    <magazineSize>40</magazineSize>
                    <reloadTime>4.0</reloadTime>
                    <ammoSet>AmmoSet_MiliraParticleSMG_Blast</ammoSet>
                    <chargedAmmoSet>AmmoSet_MiliraParticleSMGCharged_Blast</chargedAmmoSet>
                </propsUnderBarrel>
                <propsFireModesUnderBarrel>
                    <aiAimMode>Snapshot</aiAimMode>
                    <aiUseBurstMode>false</aiUseBurstMode>
                    <aimedBurstShotCount>1</aimedBurstShotCount>
