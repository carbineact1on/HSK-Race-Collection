  <!-- EN: plasma cannon -->
  <Milira_PlasmaCannon.label>离子冲击炮</Milira_PlasmaCannon.label>
  <!-- EN: A portable launcher capable of firing ion clusters which can melt the armor of targets.\nChargeable. -->
  <Milira_PlasmaCannon.description>能够发射离子团的便携式发射器，发射的离子团能够融毁命中单位的护甲。\n\n可以充能。</Milira_PlasmaCannon.description>
  <!-- EN: stock -->
  <Milira_PlasmaCannon.tools.stock.label>炮身</Milira_PlasmaCannon.tools.stock.label>
  <!-- EN: barrel -->
  <Milira_PlasmaCannon.tools.barrel.label>炮管</Milira_PlasmaCannon.tools.barrel.label>
