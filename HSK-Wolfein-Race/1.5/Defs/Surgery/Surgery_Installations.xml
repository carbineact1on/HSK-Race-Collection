<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- 安装人工假狼耳 -->
    <RecipeDef ParentName="SurgeryInstallBodyPartArtificialBase">
        <defName>Wolfein_InstallArtificialEar</defName>
        <label>install artificial ear</label>
        <description>Installing an artificial ear for the Wolfein.</description>
        <workerClass>Recipe_InstallArtificialBodyPart</workerClass>
        <jobString>Installing wolfein artificial ear.</jobString>
        <workAmount>4000</workAmount>
        <skillRequirements>
            <Medicine>5</Medicine>
        </skillRequirements>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_ArtificialEar</ThingDef>
            <HediffDef>Wolfein_ArtificialEarInstalled</HediffDef>
        </descriptionHyperlinks>
        <ingredients>
            <li>
                <filter>
                    <categories>
                        <li>Medicine</li>
                    </categories>
                </filter>
                <count>2</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Wolfein_ArtificialEar</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <categories>
                <li>Medicine</li>
            </categories>
            <thingDefs>
                <li>Wolfein_ArtificialEar</li>
            </thingDefs>
        </fixedIngredientFilter>
        <appliedOnFixedBodyParts>
            <li>Ear</li>
        </appliedOnFixedBodyParts>
        <addsHediff>Wolfein_ArtificialEarInstalled</addsHediff>
    </RecipeDef>

