<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- 太空盔 -->
    <ThingDef ParentName="Wolfein_OverHeadBase_CombatII">
        <defName>Wolfein_SpaceSuitHelmet</defName>
        <label>Wolfein Space Suit Helmet</label>
        <description>Used in conjunction with space activity suits. The display screen on the helmet can show the user's physical condition in real time, and the built-in heater effectively reduces the likelihood of migraines.</description>
        <costList>
            <ComponentIndustrial>3</ComponentIndustrial>
            <Wolfein_AlloyMaterials>30</Wolfein_AlloyMaterials>
            <Wolfein_CompositeFabric>20</Wolfein_CompositeFabric>
        </costList>
        <costStuffCount>40</costStuffCount>
        <stuffCategories>
            <li>Metallic</li>
        </stuffCategories>
        <graphicData>
            <texPath>Wolfein/Apparel/OverHead/SpaceSuitHelmet/SpaceSuitHelmet</texPath>
            <shaderType>CutoutComplex</shaderType>
            <drawSize>2.0</drawSize>
        </graphicData>
        <recipeMaker>
            <!-- <unfinishedThingDef>Wolfein_UnfinishedApparel</unfinishedThingDef> -->
            <recipeUsers Inherit="false">
                <li>Wolfein_TableMachining</li>
            </recipeUsers>
            <researchPrerequisites Inherit="false">
                <li>Wolfein_Apparel_Spacer</li>
            </researchPrerequisites>
        </recipeMaker>
        <statBases>
            <Mass>1.5</Mass>
            <MaxHitPoints>400</MaxHitPoints>
            <WorkToMake>28000</WorkToMake>
            <ArmorRating_Sharp>10</ArmorRating_Sharp>
            <ArmorRating_Blunt>27</ArmorRating_Blunt>
            <ArmorRating_Heat>0.80</ArmorRating_Heat>
            <StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
            <Insulation_Cold>10</Insulation_Cold>
            <EquipDelay>5.0</EquipDelay>
        </statBases>
        <apparel>
            <useWornGraphicMask>true</useWornGraphicMask>
            <developmentalStageFilter>Adult</developmentalStageFilter>
            <bodyPartGroups>
                <li>FullHead</li>
            </bodyPartGroups>
            <renderSkipFlags>
                <li>Wolfein_Hair</li>
            </renderSkipFlags>
            <wornGraphicPath>Wolfein/Apparel/OverHead/SpaceSuitHelmet/SpaceSuitHelmet</wornGraphicPath>
            <tags>
                <li>Wolfein_AhogeCover</li>
                <li>Wolfein_EyebrowCover</li>
                <li>Wolfein_HairCover</li>
            </tags>
            <defaultOutfitTags>
                <li>Soldier</li>
            </defaultOutfitTags>
            <drawData>
                <dataNorth>
                    <layer>280</layer>
                </dataNorth>
                <dataSouth>
                    <layer>280</layer>
                </dataSouth>
                <dataEast>
                    <layer>280</layer>
                </dataEast>
                <dataWest>
                    <layer>280</layer>
                </dataWest>
            </drawData>
        </apparel>
        <equippedStatOffsets>
            <HypoxiaResistance>0.8</HypoxiaResistance>
        </equippedStatOffsets>
    </ThingDef>

</Defs>