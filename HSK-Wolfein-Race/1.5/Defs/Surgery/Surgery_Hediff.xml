<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- 人工假狼耳 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_ArtificialEarInstalled</defName>
        <label>installed artificial ear</label>
        <labelNoun>an installed artificial ear</labelNoun>
        <description>An already installed artificial ear, though it may cause some initial discomfort for the user.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_ArtificialEar</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_ArtificialEar</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>0.85</partEfficiency>
            <betterThanNatural>false</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!-- 仿生狼耳 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_BionicEarInstalled</defName>
        <label>installed bionic ear</label>
        <labelNoun>an installed bionic ear</labelNoun>
        <description>An already installed bionic ear, allowing the user to perceive environmental sounds with greater clarity.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_BionicEar</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_BionicEar</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.2</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!-- 战斗机械狼耳 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_CombatBionicEarInstalled</defName>
        <label>installed combat mech ear</label>
        <labelNoun>an installed combat mech ear</labelNoun>
        <description>An installed metal mechanical ear, requiring the user some time to adapt to the enhanced hearing and directional perception provided by the device.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_CombatBionicEar</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_CombatBionicEar</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.4</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.1</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <!-- 人工假狼尾 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_ArtificialTailInstalled</defName>
        <label>installed artificial tail</label>
        <labelNoun>an installed artificial tail</labelNoun>
        <description>An already installed artificial tail—though not as aesthetically pleasing as a natural one, it's still better than having none.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_ArtificialTail</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_ArtificialTail</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>0.85</partEfficiency>
            <betterThanNatural>false</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!-- 仿生狼尾 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_BionicTailInstalled</defName>
        <label>installed bionic tail</label>
        <labelNoun>an installed bionic tail</labelNoun>
        <description>An already installed bionic tail, which requires the user some time to adjust to its new sense of balance.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_BionicTail</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_BionicTail</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.2</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
    </HediffDef>

    <!-- 战斗仿生狼尾 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_CombatBionicTailInstalled</defName>
        <label>installed combat mech tail</label>
        <labelNoun>an installed combat mech tail</labelNoun>
        <description>An installed metal mechanical tail, though not as flexible as a natural tail, provides enhanced balance and offensive power, effectively improving combat performance.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_CombatBionicTail</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_CombatBionicTail</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.4</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>0.2</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <!-- 金属指爪 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_MetalClawInstalled</defName>
        <label>installed metal claw</label>
        <labelNoun>a metal claw</labelNoun>
        <description>An already installed set of metal claws, further enhancing the user's close-combat capabilities.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_MetalClaw</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_MetalClaw</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.0</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
            <isGoodWeapon>true</isGoodWeapon>
        </addedPartProps>
        <comps>
            <li Class="HediffCompProperties_VerbGiver">
                <tools>
                    <li>
                        <label>Claw</label>
                        <capacities>
                            <li>Scratch</li>
                        </capacities>
                        <armorPenetration>0.3</armorPenetration>
                        <power>20</power>
                        <cooldownTime>0.8</cooldownTime>
                    </li>
                </tools>
            </li>
        </comps>
    </HediffDef>

    <!-- 机械义腿 -->
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>Wolfein_MechinalLegInstalled</defName>
        <label>installed mechinal leg</label>
        <labelNoun>a mechinal leg</labelNoun>
        <description>A fully installed mechanical prosthetic leg that effectively enhances the user's basic mobility and maintains stable performance across various terrains.</description>
        <descriptionHyperlinks>
            <ThingDef>Wolfein_MechinalLeg</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>Wolfein_MechinalLeg</spawnThingOnRemoved>
        <woundAnchorRange>0</woundAnchorRange>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1.0</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
            <isGoodWeapon>true</isGoodWeapon>
        </addedPartProps>
        <comps>
            <li Class="HediffCompProperties_VerbGiver">
                <tools>
                    <li>
                        <label>leg</label>
                        <capacities>
                            <li>Blunt</li>
                        </capacities>
                        <armorPenetration>0.25</armorPenetration>
                        <power>12</power>
                        <cooldownTime>1.2</cooldownTime>
                    </li>
                </tools>
            </li>
        </comps>
    </HediffDef>

</Defs>