<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>/Defs/PawnKindDef[@Name="Milira_PawnBase"]</xpath>
        <value>
            <li Class="CombatExtended.LoadoutPropertiesExtension">
                <primaryMagazineCount>
                    <min>3</min>
                    <max>5</max>
                </primaryMagazineCount>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>/Defs/PawnKindDef[@Name="Milian_PawnBase"]</xpath>
        <value>
            <li Class="CombatExtended.LoadoutPropertiesExtension">
                <primaryMagazineCount>
                    <min>8</min>
                    <max>8</max>
                </primaryMagazineCount>
            </li>
        </value>
    </Operation>

</Patch>