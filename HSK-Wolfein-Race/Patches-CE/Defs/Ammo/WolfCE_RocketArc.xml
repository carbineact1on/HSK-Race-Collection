<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--
        HSK fix: arc-fire RPG-7 variants for the Wolfein Rocket Turret.

        The original Wolfein_Turret_E used a custom Building_TurretGunForceAiming
        class that lobbed rockets in an arc (mortar-style targeting). Our CE
        port swapped that to Building_TurretGunCE for ammo consumption — but
        Building_TurretGunCE fires direct-line projectiles, so the arc was lost.

        Solution: clone the standard RPG-7 projectile family, flip flyOverhead
        on so they arc over walls, and reduce per-shot damage slightly so the
        turret's 6-shot volley doesn't one-shot every target.

        Then expose them through a Wolfein-specific AmmoSet so only this
        turret uses the arc variants — pawns with handheld RPGs still fire
        flat as expected.
    -->

    <!-- ================== Arc Projectiles ================== -->

    <ThingDef ParentName="BaseRPG7Grenade">
        <defName>Wolfein_Bullet_RPG7Grenade_HEAT_Arc</defName>
        <label>RPG-7 grenade (HEAT, arc)</label>
        <graphicData>
            <texPath>Things/Projectile/RPG/HEAT</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bullet</damageDef>
            <damageAmountBase>240</damageAmountBase>
            <armorPenetrationSharp>500</armorPenetrationSharp>
            <armorPenetrationBlunt>44.956</armorPenetrationBlunt>
            <flyOverhead>true</flyOverhead>
            <speed>120</speed>
            <shellingProps>
                <range>4</range>
                <spread>1.5</spread>
            </shellingProps>
        </projectile>
        <comps>
            <li Class="CombatExtended.CompProperties_ExplosiveCE">
                <damageAmountBase>110</damageAmountBase>
                <explosiveDamageType>Bomb</explosiveDamageType>
                <explosiveRadius>1.5</explosiveRadius>
                <explosionSound>MortarBomb_Explode</explosionSound>
                <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
            </li>
            <li Class="CombatExtended.CompProperties_Fragments">
                <fragments>
                    <Fragment_Large>3</Fragment_Large>
                    <Fragment_Small>12</Fragment_Small>
                </fragments>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="BaseRPG7Grenade">
        <defName>Wolfein_Bullet_RPG7Grenade_Thermobaric_Arc</defName>
        <label>RPG-7 grenade (Thermobaric, arc)</label>
        <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
        <graphicData>
            <texPath>Things/Projectile/RPG/Thermobaric</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bomb</damageDef>
            <damageAmountBase>110</damageAmountBase>
            <explosionRadius>3.0</explosionRadius>
            <flyOverhead>true</flyOverhead>
            <speed>120</speed>
            <shellingProps>
                <range>4</range>
                <spread>1.5</spread>
            </shellingProps>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="BaseRPG7Grenade">
        <defName>Wolfein_Bullet_RPG7Grenade_Frag_Arc</defName>
        <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
        <label>RPG-7 grenade (Frag, arc)</label>
        <graphicData>
            <texPath>Things/Projectile/RPG/Frag</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bomb</damageDef>
            <damageAmountBase>60</damageAmountBase>
            <explosionRadius>3.5</explosionRadius>
            <flyOverhead>true</flyOverhead>
            <speed>120</speed>
            <shellingProps>
                <range>4</range>
                <spread>1.5</spread>
            </shellingProps>
        </projectile>
        <comps>
            <li Class="CombatExtended.CompProperties_Fragments">
                <fragments>
                    <Fragment_Large>4</Fragment_Large>
                    <Fragment_Small>20</Fragment_Small>
                </fragments>
            </li>
        </comps>
    </ThingDef>

    <!-- ================== Wolfein Arc AmmoSet ================== -->

    <CombatExtended.AmmoSetDef>
        <defName>Wolfein_AmmoSet_RPG7GrenadeArc</defName>
        <label>RPG-7 Grenades (arc)</label>
        <ammoTypes>
            <Ammo_RPG7Grenade_HEAT>Wolfein_Bullet_RPG7Grenade_HEAT_Arc</Ammo_RPG7Grenade_HEAT>
            <Ammo_RPG7Grenade_Thermobaric>Wolfein_Bullet_RPG7Grenade_Thermobaric_Arc</Ammo_RPG7Grenade_Thermobaric>
            <Ammo_RPG7Grenade_Frag>Wolfein_Bullet_RPG7Grenade_Frag_Arc</Ammo_RPG7Grenade_Frag>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

</Defs>
