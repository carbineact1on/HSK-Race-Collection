<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 轻型防弹衣（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_FlakJacket"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>350</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>4</Mass>
            <EquipDelay>3</EquipDelay>
            <WorkToMake>22000</WorkToMake>
            <Insulation_Cold>0</Insulation_Cold>
            <Insulation_Heat>0</Insulation_Heat>
            <ArmorRating_Sharp>7</ArmorRating_Sharp>
            <ArmorRating_Blunt>12</ArmorRating_Blunt>
            <ArmorRating_Heat>0</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>5</Bulk>
            <WornBulk>2.5</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="Wolfein_FlakJacket"]</xpath>
		<value>
			<li Class="CombatExtended.PartialArmorExt">
				<stats>
					<li>
						<ArmorRating_Sharp>0.80</ArmorRating_Sharp>
						<parts>
							<li>Neck</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.80</ArmorRating_Blunt>
						<parts>
							<li>Neck</li>
						</parts>
					</li>
				</stats>
			</li>
		</value>
	</Operation>

</Patch>
