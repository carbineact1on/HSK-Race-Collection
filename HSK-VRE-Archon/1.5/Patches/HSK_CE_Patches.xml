<?xml version="1.0" encoding="utf-8" ?>
<!-- HSK + Combat Extended patches for VRE Archon -->
<Patch>

    <!-- ============================================================ -->
    <!--  CE TOOL CONVERSION — Archoblade bladelink weapon            -->
    <!-- ============================================================ -->

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_MeleeWeapon_ArchobladeBladelink"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>handle</label>
                    <capacities>
                        <li>Blunt</li>
                    </capacities>
                    <power>12</power>
                    <cooldownTime>1.6</cooldownTime>
                    <armorPenetrationSharp>0.3</armorPenetrationSharp>
                    <armorPenetrationBlunt>3</armorPenetrationBlunt>
                </li>
                <li Class="CombatExtended.ToolCE">
                    <label>blade</label>
                    <capacities>
                        <li>VREA_Sear</li>
                    </capacities>
                    <power>30</power>
                    <cooldownTime>1.35</cooldownTime>
                    <armorPenetrationSharp>3</armorPenetrationSharp>
                    <armorPenetrationBlunt>5</armorPenetrationBlunt>
                </li>
            </tools>
        </value>
    </Operation>

    <!-- ============================================================ -->
    <!--  HSK CE ARMOR RESCALE                                        -->
    <!-- ============================================================ -->

<!-- VREA_Apparel_Archoplate — archotech-tier psychic armor -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_Apparel_Archoplate"]/statBases/ArmorRating_Sharp</xpath>
        <value><ArmorRating_Sharp>12</ArmorRating_Sharp></value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_Apparel_Archoplate"]/statBases/ArmorRating_Blunt</xpath>
        <value><ArmorRating_Blunt>32</ArmorRating_Blunt></value>
    </Operation>
    <!-- Heat already at 0.86 (CE-compatible scale), keep as-is -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="VREA_Apparel_Archoplate"]/statBases</xpath>
        <value>
            <Bulk>12</Bulk>
            <WornBulk>4.5</WornBulk>
        </value>
    </Operation>

    <!-- VRE_Leatherskin gene — natural leathery skin -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/GeneDef[defName="VRE_Leatherskin"]/statOffsets</xpath>
        <value>
            <statOffsets>
                <ArmorRating_Sharp>5</ArmorRating_Sharp>
                <ArmorRating_Blunt>5</ArmorRating_Blunt>
            </statOffsets>
        </value>
    </Operation>

    <!-- ============================================================ -->
    <!--  RAID GATING — Archon faction wealth threshold               -->
    <!-- ============================================================ -->

<!-- Archon faction has earliestRaidDays:45 already (good) but no -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/FactionDef[defName="VRE_Archons"]</xpath>
        <value>
            <raidCommonalityFromPointsCurve>
                <points>
                    <li>(0, 0)</li>
                    <li>(2500, 0)</li>
                    <li>(5000, 1)</li>
                </points>
            </raidCommonalityFromPointsCurve>
        </value>
    </Operation>

</Patch>
