<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 机械师套装（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_MechanitorSuit"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>650</MaxHitPoints>
            <Flammability>0</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>16</Mass>
            <EquipDelay>18</EquipDelay>
            <WorkToMake>80000</WorkToMake>
            <Insulation_Cold>18</Insulation_Cold>
            <Insulation_Heat>15</Insulation_Heat>
            <ArmorRating_Sharp>8</ArmorRating_Sharp>
            <ArmorRating_Blunt>4</ArmorRating_Blunt>
            <ArmorRating_Heat>0.2</ArmorRating_Heat>
            <ArmorRating_Electric>0.3</ArmorRating_Electric>
            <Bulk>1.5</Bulk>
            <WornBulk>1.9</WornBulk>
          </statBases>
        </value>
      </li>
      <li Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="Wolfein_MechanitorSuit"]</xpath>
        <value>
          <li Class="CombatExtended.PartialArmorExt">
            <stats />
          </li>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_MechanitorSuit"]/equippedStatOffsets</xpath>
		<value>
      <CarryBulk>13</CarryBulk>
      <CarryWeight>12</CarryWeight>
		</value>
	</Operation>

</Patch>
