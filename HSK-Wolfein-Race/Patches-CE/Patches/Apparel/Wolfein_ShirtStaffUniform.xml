<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 衬衫职员制服（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_ShirtStaffUniform"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>280</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>1</Mass>
            <EquipDelay>1.5</EquipDelay>
            <WorkToMake>12500</WorkToMake>
            <ArmorRating_Sharp>0.42</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.4</ArmorRating_Blunt>
            <ArmorRating_Heat>0</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>0.3</Bulk>
            <WornBulk>2.1</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_ShirtStaffUniform"]/equippedStatOffsets</xpath>
		<value>
      <CarryBulk>15</CarryBulk>
      <CarryWeight>13</CarryWeight>
		</value>
	</Operation>
</Patch>
