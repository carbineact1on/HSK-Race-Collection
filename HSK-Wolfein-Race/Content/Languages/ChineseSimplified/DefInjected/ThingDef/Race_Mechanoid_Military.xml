  <Wolfein_Mechanoid_MilitaryGiant.comps.CompTurretGun_Custom-1.turretLabel>机枪A</Wolfein_Mechanoid_MilitaryGiant.comps.CompTurretGun_Custom-1.turretLabel>
  <!-- EN: MechineGunB -->
