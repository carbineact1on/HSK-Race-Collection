    <!-- 原型机械信号激励器（固定材料） -->
    <ThingDef ParentName="Wolfein_OverHeadBase_Mechanitor">
        <defName>Wolfein_PrototypicalMechSignalBooster</defName>
        <label>Wolfein Prototypical mech signal booster</label>
        <description>The latest breakthrough from MegaCorp, this device marks a significant leap in Mechanitor support technology. Equipped with a quantum computer capable of effortlessly simulating even human cognition, users have described it as a Mechanitor tool straight out of the age of miracles.</description>
        <costList>
            <ComponentIndustrial>8</ComponentIndustrial>
            <Wolfein_AlloyMaterials>25</Wolfein_AlloyMaterials>
            <Wolfein_CompositeFabric>10</Wolfein_CompositeFabric>
        </costList>
        <generateCommonality>0</generateCommonality>
        <graphicData>
            <texPath>Wolfein/Apparel/OverHead/PrototypicalMechSignalBooster/PrototypicalMechSignalBooster</texPath>
            <shaderType>CutoutComplex</shaderType>
            <drawSize>2.0</drawSize>
        </graphicData>
        <recipeMaker>
            <unfinishedThingDef>Wolfein_UnfinishedApparel</unfinishedThingDef>
            <recipeUsers Inherit="false">
                <li>Wolfein_TableMachining</li>
            </recipeUsers>
            <researchPrerequisite>Wolfein_Industrial_production</researchPrerequisite>
