<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!--炮塔A======================================================================================-->
  <ThingDef Name="Wolfein_Turret_A" ParentName="BuildingBase">
    <defName>Wolfein_Turret_A</defName>
    <label>Wolfein Heavy Sentry Rifle</label>
    <description>The seemingly lightweight frame supports a high-caliber assault rifle, capable of effortlessly neutralizing enemies equipped with light to medium armor.</description>
    <thingClass>Building_TurretGun</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>Wolfein/Building/Security/Base_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2,2)</drawSize>
      <drawOffset>(0,0,0)</drawOffset>
      <damageData>
        <rect>(0.3,0.3,1.4,1.4)</rect>
      </damageData>
      <shadowData>
        <volume>(0.2,0.15,0.2)</volume>
        <offset>(0,0,-0.05)</offset>
      </shadowData>
    </graphicData>
    <uiIconPath>Wolfein/Building/Security/Turret_A_UI</uiIconPath>
    <uiIconScale>1.0</uiIconScale>
    <altitudeLayer>Building</altitudeLayer>
    <stealable>false</stealable>
    <rotatable>false</rotatable>
    <size>(1,1)</size>
    <statBases>
      <MaxHitPoints>350</MaxHitPoints>
      <Flammability>0</Flammability>
      <WorkToBuild>6000</WorkToBuild>
      <Mass>15</Mass>
      <Beauty>-15</Beauty>
      <ShootingAccuracyTurret>1.00</ShootingAccuracyTurret>
    </statBases>
    <costList>
      <Wolfein_AlloyMaterials>85</Wolfein_AlloyMaterials>
      <ComponentIndustrial>8</ComponentIndustrial>
      <Wolfein_MechanicalComponent>1</Wolfein_MechanicalComponent>
    </costList>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <researchPrerequisites>
      <li>Wolfein_TurretStandard</li>
    </researchPrerequisites>
    <tickerType>Normal</tickerType>
    <comps>
      <li Class="CompProperties_Stunnable">
        <affectedDamageDefs>
          <li>Stun</li>
          <li>EMP</li>
        </affectedDamageDefs>
      </li>
      <li Class="CompProperties_Explosive">
        <wickTicks>240</wickTicks>
        <explosiveRadius>3.9</explosiveRadius>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <chanceNeverExplodeFromDamage>0.5</chanceNeverExplodeFromDamage>
      </li>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>120</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
    </comps>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <fillPercent>0.3</fillPercent>
    <hasTooltip>true</hasTooltip>
    <killedLeavings>
      <ChunkSlagSteel>1</ChunkSlagSteel>
    </killedLeavings>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <designationCategory>Security</designationCategory>
    <building>
      <combatPower>80</combatPower>
      <buildingTags>
      </buildingTags>
      <ai_combatDangerous>true</ai_combatDangerous>
      <turretGunDef>Wolfein_TurretGun_A</turretGunDef>
      <turretBurstCooldownTime>4.8</turretBurstCooldownTime>
      <turretBurstWarmupTime>0.4</turretBurstWarmupTime>
      <turretTopOffset>(0, 0)</turretTopOffset>
      <turretTopDrawSize>2</turretTopDrawSize>
    </building>
    <placeWorkers>
      <li>PlaceWorker_TurretTop</li>
      <li>PlaceWorker_ShowTurretRadius</li>
    </placeWorkers>
  </ThingDef>
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Wolfein_TurretGun_A</defName>
    <label>Wolfein Heavy Sentry Rifle</label>
    <description>The seemingly lightweight frame supports a high-caliber assault rifle, capable of effortlessly neutralizing enemies equipped with light to medium armor.</description>
    <graphicData>
      <texPath>Wolfein/Building/Security/Turret_A</texPath>
