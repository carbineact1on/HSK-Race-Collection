    <!-- ==================== Ammo ========================== -->

    <ThingDef Class="CombatExtended.AmmoDef" ParentName="SpacerSmallAmmoBase">
        <defName>Ammo_MilianParticleLight</defName>
        <label>Milian Light Particle Cell</label>
        <description>Particle containment cell optimized for low-power launchers used by Milian.</description>
        <statBases>
            <Mass>0.014</Mass>
            <Bulk>0.01</Bulk>
            <MarketValue>0.23</MarketValue>
        </statBases>
        <tradeTags>
            <li>CE_AutoEnableTrade</li>
            <li>CE_AutoEnableCrafting_Milira_UniversalBench</li>
        </tradeTags>
        <thingCategories>
            <li>AmmoMilianParticleLight</li>
        </thingCategories>
        <graphicData>
            <texPath>Things/Ammo/PlasmaCell/Pistol</texPath>
            <graphicClass>CombatExtended.Graphic_StackCountRanged</graphicClass>
        </graphicData>
        <ammoClass>Plasma</ammoClass>
    </ThingDef>

    <!-- ================== Projectiles ================== -->

    <ThingDef ParentName="BaseBulletCE" Name="Bullet_MilianParticleBeamGun">
        <defName>Bullet_MilianParticleBeamGun</defName>
        <label>Particle beam</label>
        <thingClass>CombatExtended.BulletCE</thingClass>
        <graphicData>
            <texPath>Milira/Projectile/MiliraBullet_PiecesParticleGun</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>TransparentPostLight</shaderType>
            <drawSize>1.0</drawSize>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bullet</damageDef>
            <damageAmountBase>13</damageAmountBase>
            <armorPenetrationSharp>4.5</armorPenetrationSharp>
            <armorPenetrationBlunt>11</armorPenetrationBlunt>
            <stoppingPower>0.8</stoppingPower>
            <speed>82</speed>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="BaseBulletCE">
        <defName>Bullet_MilianPulsedBeamGun</defName>
        <label>pulse beam</label>
        <thingClass>CombatExtended.BulletCE</thingClass>
        <graphicData>
            <texPath>Milira/Projectile/MiliraBullet_PiecesEMPGun</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>TransparentPostLight</shaderType>
            <drawSize>1.2</drawSize>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <flyOverhead>false</flyOverhead>
            <damageDef>Milira_PlasmaBullet</damageDef>
            <damageAmountBase>8</damageAmountBase>
            <armorPenetrationSharp>2.5</armorPenetrationSharp>
            <armorPenetrationBlunt>6.5</armorPenetrationBlunt>
            <stoppingPower>0.8</stoppingPower>
            <speed>80</speed>
            <secondaryDamage>
                <li>
                    <def>EMP</def>
                    <amount>25</amount>
                </li>
            </secondaryDamage>
        </projectile>
    </ThingDef>

    <ThingDef Name="BaseMilianParticleBullet" ParentName="BaseBulletCE" Abstract="true">
        <thingClass>CombatExtended.BulletCE</thingClass>
        <graphicData>
            <texPath>Milira/ProjectileNew/Bullet_Particle</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>TransparentPostLight</shaderType>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bullet</damageDef>
            <damageAmountBase>15</damageAmountBase>
            <armorPenetrationSharp>6</armorPenetrationSharp>
            <armorPenetrationBlunt>12</armorPenetrationBlunt>
            <stoppingPower>1.5</stoppingPower>
            <speed>100</speed>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="BaseMilianParticleBullet">
        <defName>Bullet_MiliraParticleSMG</defName>
        <label>particle beam</label>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bullet</damageDef>
            <damageAmountBase>12</damageAmountBase>
            <armorPenetrationSharp>3.5</armorPenetrationSharp>
            <armorPenetrationBlunt>10</armorPenetrationBlunt>
            <stoppingPower>0.5</stoppingPower>
            <speed>90</speed>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="Bullet_MilianParticleBeamBlasterCharged">
        <defName>Bullet_MiliraParticleSMG_Blast</defName>
    </ThingDef>

    <ThingDef ParentName="BaseExplosiveBullet">
        <defName>Bullet_MiliraParticleSMGCharged_Blast</defName>
        <label>explosive particle</label>
        <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Milira_ParticleBomb</damageDef>
            <explosionRadius>2.5</explosionRadius>
            <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
            <damageAmountBase>71</damageAmountBase>
            <stoppingPower>2.4</stoppingPower>
            <speed>125</speed>
        </projectile>
        <graphicData>
            <texPath>Milira/ProjectileNew/Bullet_ParticleExplode</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1.5,1.5)</drawSize>
            <shaderType>TransparentPostLight</shaderType>
        </graphicData>
        <modExtensions>
            <li Class="AncotLibrary.ExplosiveProjectileExtension">
                <doTrail>true</doTrail>
                <trailFleck>Milira_AirPuffGlow</trailFleck>
                <trailFreauency>1</trailFreauency>
                <trailColor>(0.86,0.87,0.70)</trailColor>
            </li>
        </modExtensions>
        <comps>
            <li Class="MiliraCE.CompProperties_ProjectileFleckColorable">
                <FleckDatas>
                    <li>
                        <fleck>Milira_AirPuffGlow</fleck>
                        <fleckColor>(0.86,0.87,0.70)</fleckColor>
                        <emissionsPerTick>1</emissionsPerTick>
                        <flecksPerEmission>1</flecksPerEmission>
                        <scale>1</scale>
                    </li>
                </FleckDatas>
            </li>
        </comps>
    </ThingDef>

