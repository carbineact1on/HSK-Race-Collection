    <!-- 机炮 -->
    <ThingDef ParentName="BaseGun">
        <defName>W_Weapon_MG_Autocannon</defName>
        <label>Wolfein mech autocannon</label>
        <description>A medium-caliber automatic weapon system mounted on MegaCorp-manufactured mechanical units, designed for sustained fire suppression and anti-infantry operations. Its modular structure allows for easy maintenance and replacement. While not as destructive as heavy artillery, it proves highly effective in intense combat scenarios.</description>
        <tradeability>None</tradeability>
        <destroyOnDrop>true</destroyOnDrop>
        <relicChance>0</relicChance>
        <graphicData>
            <texPath>Wolfein/Weapon/Autocannon</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>3.0</drawSize>
        </graphicData>
        <uiIconScale>1</uiIconScale>
        <soundInteract>Wolfein_WeaponInteract</soundInteract>
        <techLevel>Industrial</techLevel>
        <weaponClasses>
            <li>RangedHeavy</li>
        </weaponClasses>
        <weaponTags>
            <li>Wolfein_HeavyMech</li>
        </weaponTags>
        <equippedStatOffsets>
            <MoveSpeed>-0.25</MoveSpeed>
        </equippedStatOffsets>
        <statBases>
            <WorkToMake>70000</WorkToMake>
            <MarketValue>1320</MarketValue>
            <Mass>16</Mass>
            <AccuracyTouch>0.60</AccuracyTouch>
            <AccuracyShort>0.68</AccuracyShort>
            <AccuracyMedium>0.78</AccuracyMedium>
            <AccuracyLong>0.68</AccuracyLong>
            <RangedWeapon_Cooldown>2.0</RangedWeapon_Cooldown>
        </statBases>
        <costList>
        </costList>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>W_Bullet_Autocannon</defaultProjectile>
                <warmupTime>2.8</warmupTime>
                <range>40</range>
                <minRange>3.0</minRange>
                <burstShotCount>5</burstShotCount>
                <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
                <forcedMissRadius>0.1</forcedMissRadius>
                <soundCast>Shot_Minigun</soundCast>
                <soundCastTail>GunTail_Medium</soundCastTail>
                <muzzleFlashScale>9</muzzleFlashScale>
            </li>
        </verbs>
        <tools>
            <li>
                <label>stock</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>12</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>12</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>
