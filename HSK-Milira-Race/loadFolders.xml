<?xml version="1.0" encoding="utf-8"?>
<loadFolders>
	<v1.5>
		<li>/</li>
		<li>1.5</li>
		<li>Content</li>
		<li IfModActive="Ludeon.RimWorld.Royalty">1.5/Mods/Royalty</li>
		<li IfModActive="Ludeon.RimWorld.Biotech">1.5/Mods/Biotech</li>
		<li IfModActive="Ancot.KiiroRace">1.5/Mods/Ancot.KiiroRace</li>
		<!-- CE base patch + common language files (load when CE is active) -->
		<li IfModActive="CETeam.CombatExtended">Patches-CE</li>
		<li IfModActive="CETeam.CombatExtended">Patches-CE/Common</li>
		<!-- CE x submod compatibility patches: IfModActive comma-list is OR-semantic in
		     RimWorld 1.5, so listing two mods loads the path if EITHER is active. Since
		     the Patches-CE root path already gates on CE, we only need to gate the submod
		     check here. If a user has the submod but not CE, the CE-specific xpath in
		     these patches will fail silently (harmless) since Patches-CE root won't load. -->
		<li IfModActive="Ludeon.RimWorld.Biotech">Patches-CE/Mods/Biotech</li>
		<li IfModActive="Ancot.KiiroRace">Patches-CE/Mods/Ancot.KiiroRace</li>
		<li IfModActive="Ancot.MilianModification">Patches-CE/Mods/Ancot.MilianModification</li>
	</v1.5>
</loadFolders>
