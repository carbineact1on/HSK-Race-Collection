<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 商务职员服（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_BusinessUniform"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>280</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>1</Mass>
            <EquipDelay>1.5</EquipDelay>
            <WorkToMake>12500</WorkToMake>
            <Insulation_Cold>15</Insulation_Cold>
            <Insulation_Heat>18</Insulation_Heat>
            <ArmorRating_Sharp>3</ArmorRating_Sharp>
            <ArmorRating_Blunt>2</ArmorRating_Blunt>
            <ArmorRating_Heat>0</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>1</Bulk>
            <WornBulk>0.7</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_BusinessUniform"]/equippedStatOffsets</xpath>
		<value>
      <CarryBulk>5</CarryBulk>
      <CarryWeight>3</CarryWeight>
		</value>
	</Operation>

</Patch>
