<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- ==================== Recipes ========================== -->

	<RecipeDef ParentName="LauncherAmmoRecipeBase">
		<defName>Make_WolfGrenades</defName>
		<label>make Wolfein Grenades x10</label>
		<description>Craft 10 Wolfein grenades.</description>
		<jobString>Making Wolfein grenades.</jobString>
		<researchPrerequisite>Wolfein_BlastWeapon</researchPrerequisite>
		<!-- HSK fix: removed CE_Launchers research prereq — that ResearchProjectDef
		     is disabled in HSK's CE install (ResearchProjects.xml.bak). Wolfein_BlastWeapon
		     alone is sufficient gating. Also collapsed plural list to singular for
		     consistency with the rest of the fork's research prereq style. -->

		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>SteelBar</li>
					</thingDefs>
				</filter>
				<count>16</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>FSX</li>
					</thingDefs>
				</filter>
				<count>9</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>SteelBar</li>
				<li>FSX</li>
				<li>ComponentIndustrial</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<W_Weapon_Grenade_FragGrenade>10</W_Weapon_Grenade_FragGrenade>
		</products>
		<workAmount>5000</workAmount>
		<recipeUsers Inherit="false">
			<li>WeaponCraftingWorkTable</li>
		</recipeUsers>
	</RecipeDef>

	<!--
		HSK fork note: removed Make_WolfeinGasGrenade recipe entirely.
		It produced W_Weapon_Grenade_GasGrenade x10, but that ThingDef
		is 1.6-only content not present in our 1.5 fork. The recipe was
		causing a "Could not resolve cross-reference: No Verse.ThingDef
		named W_Weapon_Grenade_GasGrenade found to give to
		Verse.ThingDefCountClass (10x null)" boot error.

		Steel raw ore -> SteelBar (1:5 HSK refined alloy ratio): the
		surviving Make_WolfGrenades recipe was using 76 Steel; converted
		to 16 SteelBar.

		Bench routing: was Wolfein_TableMachining, now WeaponCraftingWorkTable
		(matches the fork's "all Wolfein recipes route to HSK benches"
		pattern).
	-->

</Defs>
