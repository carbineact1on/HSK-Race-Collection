<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 特种作战服（固定材料） -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Wolfein_SpecialmilitaryUniform"]/statBases</xpath>
        <value>
          <statBases>
            <MaxHitPoints>320</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <DeteriorationRate>1</DeteriorationRate>
            <Beauty>2</Beauty>
            <Mass>2</Mass>
            <EquipDelay>3</EquipDelay>
            <WorkToMake>20000</WorkToMake>
            <Insulation_Cold>10</Insulation_Cold>
            <Insulation_Heat>10</Insulation_Heat>
            <ArmorRating_Sharp>7.8</ArmorRating_Sharp>
            <ArmorRating_Blunt>9</ArmorRating_Blunt>
            <ArmorRating_Heat>0.15</ArmorRating_Heat>
            <ArmorRating_Electric>0</ArmorRating_Electric>
            <Bulk>1</Bulk>
            <WornBulk>3</WornBulk>
          </statBases>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Wolfein_SpecialmilitaryUniform"]/equippedStatOffsets</xpath>
		<value>
      <CarryBulk>15</CarryBulk>
      <CarryWeight>21</CarryWeight>
		</value>
	</Operation>
</Patch>
