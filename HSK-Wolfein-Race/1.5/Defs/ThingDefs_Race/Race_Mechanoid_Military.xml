    <!-- 超重型多足火力平台 -->
    <ThingDef ParentName="Wolfein_BaseMechMilitary">
        <defName>Wolfein_Mechanoid_MilitaryGiant</defName>
        <label>Extra Heavy Multi-Legged Firepower Platform.</label>
        <description>The extra heavy multi-legged firepower platform, the largest active mech in the MegaCorp arsenal, requires approval from the highest local military authority for each deployment. Its weapons are powerful enough to breach the enemy's most fortified defenses after just a few shots.</description>
        <uiIconScale>1.2</uiIconScale>
        <statBases>
            <MoveSpeed>2.6</MoveSpeed>
            <ArmorRating_Blunt>1.5</ArmorRating_Blunt>
            <ArmorRating_Sharp>1.8</ArmorRating_Sharp>
            <BandwidthCost MayRequire="Ludeon.Rimworld.Biotech">10</BandwidthCost>
            <EMPResistance MayRequire="Ludeon.RimWorld.Biotech">0.8</EMPResistance>
            <MechEnergyLossPerHP MayRequire="Ludeon.Rimworld.Biotech">0.06</MechEnergyLossPerHP>
        </statBases>
        <race>
            <baseHealthScale>6</baseHealthScale>
            <baseBodySize>5.5</baseBodySize>
            <body>Wolfein_GiantMech</body>
            <mechWeightClass>UltraHeavy</mechWeightClass>
            <thinkTreeConstant MayRequire="Ludeon.RimWorld.Biotech">Wolfein_GiantMechConstant</thinkTreeConstant>
        </race>
        <tools Inherit="false">
            <li>
                <label>blunt</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>60.0</power>
                <cooldownTime>4.0</cooldownTime>
                <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
            </li>
        </tools>
        <butcherProducts Inherit="False">
            <SteelBar>45</SteelBar>
            <Wolfein_AlloyMaterials>80</Wolfein_AlloyMaterials>
            <Plasteel>125</Plasteel>
        </butcherProducts>
        <comps>
            <li Class="Wolfein.CompProperties_TurretGun_Custom">
                <turretDef>Wolfein_GiantTurret</turretDef>
                <turretLabel>GiantTurret</turretLabel>
                <num>1</num>
                <angleOffset>-90</angleOffset>
                <autoAttack>false</autoAttack>
                <gizmoIconPath_Aim>Wolfein/UI/Aiming_Turret</gizmoIconPath_Aim>
                <renderNodeProperties>
                    <li Class="Wolfein.PawnRenderNodeProperties_TurretGun_Custom">
                        <nodeClass>Wolfein.PawnRenderNode_TurretGun_Custom</nodeClass>
                        <workerClass>Wolfein.PawnRenderNodeWorker_TurretGun_Custom</workerClass>
                        <overrideMeshSize>(6, 6)</overrideMeshSize>
                        <parentTagDef>Body</parentTagDef>
                        <baseLayer>30</baseLayer>
                        <pawnType>Any</pawnType>
                        <drawData>
                            <dataWest>
                                <rotationOffset>180</rotationOffset>
                            </dataWest>
                        </drawData>
                    </li>
                </renderNodeProperties>
            </li>
            <li Class="Wolfein.CompProperties_TurretGun_Custom">
                <turretDef>Wolfein_GiantTurret_MechineGun</turretDef>
                <turretLabel>MechineGunA</turretLabel>
                <primaryWeapon>false</primaryWeapon>
                <num>2</num>
                <gizmoIconPath_Aim>Wolfein/UI/Aiming_MG</gizmoIconPath_Aim>
                <saveKeysPrefix>One</saveKeysPrefix>
                <angleOffset>-90</angleOffset>
                <autoAttack>false</autoAttack>
            </li>
            <li Class="Wolfein.CompProperties_TurretGun_Custom">
                <turretDef>Wolfein_GiantTurret_MechineGun</turretDef>
                <turretLabel>MechineGunB</turretLabel>
                <primaryWeapon>false</primaryWeapon>
                <num>3</num>
                <gizmoIconPath_Aim>Wolfein/UI/Aiming_MG</gizmoIconPath_Aim>
                <saveKeysPrefix>Two</saveKeysPrefix>
                <angleOffset>-90</angleOffset>
                <autoAttack>false</autoAttack>
            </li>
            <li Class="Wolfein.CompProperties_TurretControl">
                <gizmoA>Wolfein/UI/Aiming_Turret</gizmoA>
                <gizmoB>Wolfein/UI/Aiming_MG</gizmoB>
            </li>
        </comps>
    </ThingDef>
