<?xml version="1.0" encoding="utf-8" ?>
<!--
    HSK FULL conversion for VRE Android.

    Two categories:

    1. BUILDINGS — Switch from fixed Steel/Gold to stuffCategories Metallic +
       costStuffCount, and add the HSK class component pipeline (ElecComp,
       Mechanism, Electronics, Microchips, Glass) to match HSK Biotech
       convention on tech buildings:
         AndroidStand                — small storage furniture
         AndroidPartWorkbench        — industrial fabrication bench
         SubcorePolyanalyzer         — ultratech analyzer (Plasteel + CompSpacer)
         AndroidCreationStation      — high-tech android assembler (Glass + Mech
                                       to match HSK LargeMechGestator pattern)
         AndroidBehavioristStation   — software/programming bench (GoldBar)
         NeutroCasket                — neutroamine storage (Electronics 1 to
                                       match HSK DeathrestCasket pattern)

    2. BODY PARTS — All 15 craftable artificial body parts rewritten to
       match HSK Bionic / Cybernetic body part patterns from Core_SK/Defs/
       BodyParts/. Android body parts are PREMIUM endgame craftables — same
       Hyperweave/CarbonAlloy/SyntheticFibers/Microchips/ComponentAdvanced/
       Biomatter/ArtificialBone/Paraffins/ReinforcedGlass profile that HSK
       bionic body parts use.

       Heart-tier organs (Hyperweave-based):
         VREA_NeuroPump          → BionicHeart pattern
         VREA_AirFilter          → BionicLung pattern
         VREA_Neutrofilter       → BionicKidney pattern
         VREA_MetabolismRegulator → BionicStomach pattern + GoldBar
       Cybernetic-tier (top-tier ArchotechHeart-style):
         VREA_Reactor            → ComponentUltra/BioMicrochips + DepletedUranium
         VREA_ArtificialBrain    → ComponentUltra/BioMicrochips
       Sensory parts:
         VREA_OpticalUnit        → BionicEye pattern
         VREA_AudioProcessor     → BionicEar pattern
         VREA_ArtificialNose     → simple bionic sensory
       Skeletal/structural (ComponentAdvanced + Biomatter + ArtificialBone):
         VREA_ArtificialJaw      → BionicJaw pattern
         VREA_ArtificialRibcage  → BionicNeck-style pattern
         VREA_ArtificialSpine    → BionicSpine pattern + GoldBar
       Limbs:
         VREA_AndroidLeg         → BionicLeg pattern
         VREA_AndroidFoot        → BionicFoot pattern
         VREA_AndroidArm         → BionicArm pattern
         VREA_AndroidHand        → BionicHand pattern

    All HSK material defs verified present in Core_SK:
      Hyperweave, CarbonAlloy, SyntheticFibers, Microchips, ComponentAdvanced,
      Biomatter, ArtificialBone, ReinforcedGlass, Paraffins, Glass,
      ComponentUltra, BioMicrochips, GoldBar, DepletedUranium.

    No CE work needed — androids do not have natural melee weapons.
-->
<Patch>

    <!-- ============================================================ -->
    <!--  BUILDINGS — full HSK pattern conversion                     -->
    <!-- ============================================================ -->

    <!-- VREA_AndroidStand (1x1 small storage furniture) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_AndroidStand"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>50</costStuffCount>
            <costList>
                <ComponentIndustrial>1</ComponentIndustrial>
            </costList>
        </value>
    </Operation>

    <!-- VREA_AndroidPartWorkbench (industrial fabrication bench) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_AndroidPartWorkbench"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>220</costStuffCount>
            <costList>
                <ComponentIndustrial>8</ComponentIndustrial>
                <ElectronicComponents>2</ElectronicComponents>
                <Mechanism>2</Mechanism>
                <Electronics>2</Electronics>
            </costList>
        </value>
    </Operation>

    <!-- VREA_SubcorePolyanalyzer (ultratech analyzer) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_SubcorePolyanalyzer"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>200</costStuffCount>
            <costList>
                <Plasteel>150</Plasteel>
                <ComponentSpacer>3</ComponentSpacer>
                <ElectronicComponents>2</ElectronicComponents>
                <Microchips>2</Microchips>
            </costList>
        </value>
    </Operation>

    <!-- VREA_AndroidCreationStation (LargeMechGestator-tier) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_AndroidCreationStation"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>360</costStuffCount>
            <costList>
                <Glass>40</Glass>
                <ComponentIndustrial>6</ComponentIndustrial>
                <ComponentSpacer>6</ComponentSpacer>
                <ElectronicComponents>3</ElectronicComponents>
                <Mechanism>2</Mechanism>
                <Microchips>3</Microchips>
            </costList>
        </value>
    </Operation>

    <!-- VREA_AndroidBehavioristStation (software/programming bench) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_AndroidBehavioristStation"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>160</costStuffCount>
            <costList>
                <ComponentIndustrial>4</ComponentIndustrial>
                <ComponentSpacer>4</ComponentSpacer>
                <GoldBar>20</GoldBar>
                <ElectronicComponents>2</ElectronicComponents>
                <Microchips>2</Microchips>
            </costList>
        </value>
    </Operation>

    <!-- VREA_NeutroCasket (DeathrestCasket-tier) -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VREA_NeutroCasket"]/costList</xpath>
        <value>
            <stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
            <costStuffCount>180</costStuffCount>
            <costList>
                <ComponentIndustrial>3</ComponentIndustrial>
                <ElectronicComponents>1</ElectronicComponents>
                <Mechanism>1</Mechanism>
                <Electronics>1</Electronics>
            </costList>
        </value>
    </Operation>

    <!-- ============================================================ -->
    <!--  Strip inherited constructEffect for buildings now madeFromStuff -->
    <!--  (constructEffect + stuffCategories causes a config error)   -->
    <!-- ============================================================ -->

    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="VREA_AndroidPartWorkbench"]/constructEffect</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="VREA_AndroidCreationStation"]/constructEffect</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="VREA_AndroidBehavioristStation"]/constructEffect</xpath>
    </Operation>

    <!-- NOTE: VREA body parts (NeuroPump, AirFilter, AndroidLeg, etc.) are
         HediffDefs only — they are gene-applied / innate, NOT crafted as
         ThingDef items. There is no costList to patch. Removed all 15
         body-part PatchOperationReplace ops that targeted nonexistent
         ThingDefs. -->

</Patch>
